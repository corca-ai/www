{
  "name": "corca-www",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "cf:preview": "astro build && wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "astro": "astro",
    "lint": "biome check && astro check",
    "format": "biome check --write && awiki format -root docs",
    "dup": "nose query src",
    "knip": "knip",
    "docs:lint": "awiki lint -root docs",
    "docs:format": "awiki format -root docs",
    "check": "biome check && astro check && knip && nose query src --mode syntax 'dup>80' --fail-on any && awiki lint -root docs",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.5",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.5.2",
    "@tailwindcss/vite": "^4.3.2",
    "knip": "^6.24.0",
    "lefthook": "^2.1.9",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.106.0"
  }
}
