{
  "name": "corca-www",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/sync-blog-shell-assets.js",
    "preview": "astro preview",
    "cf:preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "release:site": "bash scripts/release-site.sh",
    "astro": "astro",
    "check:biome": "biome check",
    "check:astro": "astro check",
    "check:knip": "knip",
    "check:dup": "nose query src --mode syntax 'dup>80' --fail-on any",
    "check:docs": "awiki lint -root docs",
    "blog:content:apply": "node scripts/apply-admin-post-change.js",
    "blog:content:check": "node scripts/admin-post-change-check.js",
    "blog:shell:sync": "node scripts/sync-blog-shell-assets.js",
    "notion:publish": "node scripts/sync-notion-posts.js",
    "notion:check": "node scripts/notion-publish-check.js",
    "check": "pnpm check:biome && pnpm check:astro && pnpm check:knip && pnpm check:dup && pnpm check:docs",
    "lint": "pnpm check:biome && pnpm check:astro",
    "format": "biome check --write && awiki format -root docs",
    "dup": "nose query src",
    "docs:lint": "awiki lint -root docs",
    "docs:format": "awiki format -root docs",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.5",
    "markdown-it": "^14.3.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.5.2",
    "@tailwindcss/vite": "^4.3.2",
    "knip": "^6.24.0",
    "lefthook": "^2.1.9",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "wrangler": "^4.106.0"
  }
}
