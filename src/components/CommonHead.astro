---
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  isAxPage?: boolean;
}

const { lang, isAxPage = false } = Astro.props;
const publisherName = { ko: '코르카', en: 'Corca', ja: 'コルカ', zh: 'Corca' }[lang];
---

<!-- corca-common-head:start -->
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/favicon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#ffffff" />
<meta name="application-name" content="Corca" />
<meta name="apple-mobile-web-app-title" content="Corca" />
<meta name="publisher" content={publisherName} />

<!-- AX mobile uses a unicode-range dynamic subset; desktop and all other
     pages keep the existing full Pretendard preload. -->
{isAxPage && (
  <link
    rel="stylesheet"
    href="/fonts/pretendard-mobile/pretendard-mobile.css"
    media="(max-width: 720px)"
  />
)}
<link
  rel="preload"
  href="/fonts/PretendardVariable.woff2"
  as="font"
  type="font/woff2"
  crossorigin
  media={isAxPage ? '(min-width: 721px)' : undefined}
/>
<!-- corca-common-head:end -->
