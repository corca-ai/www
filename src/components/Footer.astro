---
import { useTranslations } from '../i18n/utils';
import { contact, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="bg-footer text-white/70">
  <div class="container-c flex flex-col items-center gap-5 py-14 text-center max-md:items-start max-md:text-left">
    <!-- Same corca-logo.svg as the header, recolored via CSS mask (an <img> can't
         restyle an external SVG's fill; the mask paints the logo shape in #666). -->
    <span
      role="img"
      aria-label="Corca"
      class="block h-[24px] w-[86px]"
      style="background-color:#666666; -webkit-mask:url('/corca-logo.svg') no-repeat center / contain; mask:url('/corca-logo.svg') no-repeat center / contain;"
    ></span>
    <address class="text-[13px] not-italic leading-[1.5] text-[#bbbbbb]">
      <p>{t.footer.address}</p>
      <p>
        <a href="tel:+82-2-6925-6978">{t.footer.tel}</a>
        <span class="inline-block w-3"></span>
        <a href={`mailto:${contact.email}`}>{contact.email}</a>
      </p>
    </address>
    <p class="text-[12px] text-[#bbbbbb]">{t.footer.rights}</p>
  </div>
</footer>
