---
import { contact, type Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const HERO_BG = '/images/pages/2fe9a6_d35d2743fc2342df884222c5a0d125ee.webp';
const LOGO = '/images/pages/5cb5de_4a84baab528e42b797e2b35189e6661a.webp';

// Naver map link (live's Contact section shows a single filled "map" button).
const MAP_URL = 'https://map.naver.com/p/entry/place/1354855657';
// Embedded Google Map of the office, like the original site's contact section.
const MAP_EMBED = (hl: string) =>
  `https://maps.google.com/maps?q=${encodeURIComponent('11-8 Teheran-ro 77-gil, Gangnam-gu, Seoul')}&z=16&hl=${hl}&output=embed`;
const mapLang: Record<Lang, string> = { ko: 'ko', en: 'en', ja: 'ja', zh: 'zh-CN' };
const contactLinks = {
  ko: { careers: '채용 안내', map: '지도 확인', mapTitle: '코르카 오시는 길 지도' },
  en: { careers: 'Careers', map: 'Open in Naver Map', mapTitle: 'Map to the Corca office' },
  ja: { careers: '採用情報', map: 'NAVERマップで見る', mapTitle: 'コルカへのアクセスマップ' },
  zh: { careers: '招聘信息', map: '在Naver地图中查看', mapTitle: 'Corca办公室位置地图' },
};

// Branded value names stay in English across locales (as on the original).
const valueNames = ['Creative Idea', 'Better Future', 'People', 'Theory', 'Helping Hands'];

const content = {
  ko: {
    heroTitle: '기술 발전의 혜택을 모두가 누리게 하여\n인류 문명의 발전에 기여합니다',
    missionTitle: 'AI로 삶과 일의 패러다임을 바꿉니다',
    missionBody:
      '코르카는 상상을 현실로 바꾸는 AI 기술을 선도합니다. 탁월한 솔루션과 윤리적 리더십, 글로벌 임팩트를 핵심 가치로 삼고, 고객 중심의 서비스와 끊임없는 연구 개발에 힘씁니다. 기술 발전의 혜택을 모두가 누리게 하여 인류 문명의 발전에 기여하는 게 우리의 미션입니다.',
    valueDescs: ['창의적인 아이디어', '더 나은 사회, 문화, 문명 지향', '사람 중심, 인류애', '탄탄한 이론과 연구에 기반한 의사결정', '나만이 아닌, 우리와 모두, 코르카와 함께'],
    ethicalTitle: '더 밝은 미래를 위한 윤리적 AI',
    ethicalSubtitle: '코르카는 상상을 현실로 만드는 AI 기술을 선도하며, 높은 기술력으로 더 나은 사회를 만들기 위해 혁신적 솔루션과 윤리적 리더십을 추구합니다.',
    pillars: [
      { title: '기술을 넘어선 신뢰', body: '코르카는 첨단 AI 기술의 개발과 활용에 있어 투명성과 윤리성을 최우선 가치로 삼습니다. 고객과 사회 모두가 신뢰할 수 있는 기술을 만들기 위해, 책임 있는 데이터 관리와 공정한 알고리즘 개발에 힘쓰고 있습니다.' },
      { title: '모두를 위한 혁신', body: '혁신은 소수만을 위한 것이 아니라 모두를 위한 것이라는 믿음으로, 다양한 사용자의 필요와 환경을 고려한 AI 솔루션을 제공합니다. 누구나 쉽게 접근하고 활용할 수 있는 기술로 사회적 격차를 줄이고, 모두가 함께 성장하는 미래를 만들어갑니다.' },
      { title: '모두의 일상을 바꾸는 기술', body: '코르카의 AI는 일상 속에서 실질적인 변화를 만들어냅니다. 복잡한 문제를 쉽게 해결하고, 더 편리하고 안전한 삶을 누릴 수 있도록 다양한 분야에 맞춤형 솔루션을 제공합니다. 우리의 기술은 사람들의 일상에 긍정적인 영향을 주는 것을 목표로 합니다.' },
      { title: '글로벌 AI 혁신을 선도하는 기업', body: '코르카는 국내를 넘어 글로벌 시장에서도 윤리적이고 혁신적인 AI 기술을 선도합니다. 세계 각국의 다양한 파트너와 협력하며, 글로벌 표준을 제시하는 기업으로 성장하고 있습니다. 미래를 향한 도전과 책임감을 바탕으로, 더 나은 세상을 만들어갑니다.' },
    ],
    contactLabel: 'Contact',
    locationLabel: 'Location',
    address: '서울특별시 강남구 테헤란로77길 11-8, 6층',
    phone: '02 6925 6978',
  },
  en: {
    heroTitle: 'We make technology benefit everyone\nand help human civilization move forward.',
    missionTitle: 'Changing the paradigm of life and work with AI',
    missionBody:
      'Corca is a leader in AI technology that turns imagination into reality. With excellent solutions, ethical leadership, and global impact as its core values, we strive for customer-centric services and continuous research and development. Our mission is to contribute to the advancement of human civilization by allowing everyone to enjoy the benefits of technological progress.',
    valueDescs: ['Creative ideas', 'Aiming for a better society, culture, and civilization', 'People-centered, with love for humanity', 'Decision-making based on solid theory and research', 'Not just me, but us and everyone, with Corca'],
    ethicalTitle: 'Ethical AI for a Brighter Future',
    ethicalSubtitle: 'Corca leads AI technology that turns imagination into reality, pursuing innovative solutions and ethical leadership to create a better society with advanced technology.',
    pillars: [
      { title: 'Trust Beyond Technology', body: 'Corca prioritizes transparency and ethics in the development and use of cutting-edge AI technologies. We strive to create technologies that customers and society can trust by managing data responsibly and developing fair algorithms.' },
      { title: 'Innovation for All', body: 'With the belief that innovation is not for the few but for everyone, we provide AI solutions that consider the needs and environments of diverse users. We reduce social gaps with technology anyone can easily access and use, creating a future where everyone grows together.' },
      { title: 'Technology That Changes Daily Life', body: "Corca's AI creates real change in daily life. It provides customized solutions across various fields to solve complex problems easily and make life more convenient and safe. Our technology aims to have a positive impact on people's daily lives." },
      { title: 'A Company Leading Global AI Innovation', body: 'Corca leads ethical and innovative AI technology in the global market, beyond Korea. Collaborating with diverse partners worldwide, we are growing into a company that sets global standards — building a better world based on challenge and responsibility for the future.' },
    ],
    contactLabel: 'Contact',
    locationLabel: 'Location',
    address: '6F, 11-8 Teheran-ro 77-gil, Gangnam-gu, Seoul, Korea',
    phone: '+82 2 6925 6978',
  },
  ja: {
    heroTitle: '技術の進歩の恩恵をすべての人が享受できる社会を実現し、\n人類文明の発展に貢献します。',
    missionTitle: 'AIの力で、人生と仕事のパラダイムを変革します。',
    missionBody:
      'コルカは、想像を現実に変えるAI技術の最前線をリードしています。卓越したソリューション、倫理的リーダーシップ、そしてグローバルな影響力を中核的価値とし、顧客中心のサービスと不断の研究開発に取り組んでいます。技術の進歩の恩恵をすべての人が享受できるようにし、人類文明の発展に貢献することが私たちのミッションです。',
    valueDescs: ['創造的なアイデア', 'より良い社会・文化・文明を志向', '人を中心に、人類への愛を持って', '確かな理論と研究に基づく意思決定', '私だけではなく、私たちと皆、コルカと共に'],
    ethicalTitle: 'より明るい未来のための倫理的AIを追求',
    ethicalSubtitle: 'コルカは、想像を現実に変えるAI技術をリードし、高い技術力によってより良い社会を創造するため、革新的なソリューションと倫理的リーダーシップを追求しています。',
    pillars: [
      { title: '技術を超えた信頼', body: 'コルカは、先端AI技術の開発と活用において、透明性と倫理性を最も重要な価値としています。顧客と社会の双方が信頼できる技術を実現するため、責任あるデータ管理と公正なアルゴリズムの開発に取り組んでいます。' },
      { title: 'すべての人のためのイノベーション', body: 'イノベーションは一部の人々だけのものではなく、すべての人のためのものであるという信念のもと、さまざまなユーザーのニーズと環境を考慮したAIソリューションを提供します。誰もが簡単にアクセスし活用できる技術で社会的格差を縮小し、共に成長する未来を築きます。' },
      { title: 'みんなの日常を変える技術', body: 'コルカのAIは、日常の中で実質的な変化をもたらします。複雑な問題をスマートに解決し、より便利で安全な生活を実現するため、各分野に最適化されたソリューションを提供します。私たちの技術は、人々の日常にポジティブな影響を与えることを目指しています。' },
      { title: 'グローバルAIイノベーションをリードする企業', body: 'コルカは、国内にとどまらず、グローバル市場でも倫理的かつ革新的なAI技術をリードしています。世界各国の多様なパートナーと協力し、国際標準を示す企業へと成長しています。未来への挑戦と責任感を胸に、より良い世界を築いていきます。' },
    ],
    contactLabel: 'Contact',
    locationLabel: '所在地',
    address: '6F, 11-8 Teheran-ro 77-gil, Gangnam-gu, Seoul, Korea',
    phone: '+82 2 6925 6978',
  },
  zh: {
    heroTitle: '让所有人共享技术进步的成果，\n为人类文明的发展贡献力量。',
    missionTitle: '用AI改变生活与工作的范式',
    missionBody:
      'Corca引领将想象变为现实的AI技术。我们以卓越的解决方案、道德领导力和全球影响力为核心价值，致力于以客户为中心的服务和持续的研发。让所有人共享技术进步的成果、为人类文明的发展贡献力量，是我们的使命。',
    valueDescs: ['富有创意的想法', '追求更美好的社会、文化与文明', '以人为本，心怀人类之爱', '基于扎实理论与研究的决策', '不止于我，而是我们与所有人，与Corca同行'],
    ethicalTitle: '为更光明的未来打造道德的AI',
    ethicalSubtitle: 'Corca引领将想象变为现实的AI技术，以高超的技术实力追求创新的解决方案与道德领导力，致力于创造更美好的社会。',
    pillars: [
      { title: '超越技术的信任', body: 'Corca在尖端AI技术的开发与应用中，始终将透明性与道德性作为首要价值。为了打造客户与社会都能信赖的技术，我们致力于负责任的数据管理和公平的算法开发。' },
      { title: '惠及所有人的创新', body: '我们坚信创新不是少数人的专利，而是属于每一个人。我们提供充分考虑不同用户需求与环境的AI解决方案，用人人都能轻松使用的技术缩小社会差距，共创共同成长的未来。' },
      { title: '改变每个人日常的技术', body: 'Corca的AI在日常生活中创造实实在在的改变。我们为各个领域提供量身定制的解决方案，轻松解决复杂问题，让生活更便捷、更安全。我们的技术旨在为人们的日常带来积极的影响。' },
      { title: '引领全球AI创新的企业', body: 'Corca不仅立足韩国，更在全球市场引领道德且创新的AI技术。我们与世界各地的多元伙伴合作，正成长为制定全球标准的企业。怀着对未来的挑战精神与责任感，我们不断创造更美好的世界。' },
    ],
    contactLabel: 'Contact',
    locationLabel: '地址',
    address: '6F, 11-8 Teheran-ro 77-gil, Gangnam-gu, Seoul, Korea',
    phone: '+82 2 6925 6978',
  },
};
const c = content[lang];
const cl = contactLinks[lang];
const br = (s: string) => s.replace(/\n/g, '<br />');
---

<!-- Hero — the bright underwater whale shows through; a bottom-weighted gradient
     keeps the white tagline legible, matching corca.ai. -->
<section
  class="relative min-h-[600px] bg-[#0b3a86] bg-cover bg-top md:min-h-[780px] lg:min-h-[900px]"
  style={`background-image: linear-gradient(rgba(2,20,60,0) 48%, rgba(2,15,48,0.30) 100%), url('${HERO_BG}');`}
>
  <!-- Title sits ~66% down the hero at every width (like live), not flush to the
       bottom — a width-based pb pushed it to the bottom edge on mobile. -->
  <div class="container-c absolute inset-x-0 top-[66%] -translate-y-1/2">
    <h1
      class="mx-auto max-w-[900px] text-center text-[25px] font-normal leading-[1.18] text-white [text-shadow:0_2px_14px_rgba(0,10,40,0.55)] sm:text-[34px] lg:text-[38px] xl:text-[45px]"
      set:html={br(c.heroTitle)}
    />
  </div>
</section>

<!-- Mission + values -->
<section class="bg-white">
  <div class="container-c flex flex-col items-start py-14 text-left sm:items-center sm:text-center lg:pb-24 lg:pt-40">
    <img src={LOGO} alt="Corca" width="1600" height="467" class="h-[38px] w-auto sm:h-[48px] md:h-[54px] lg:h-[96px]" />
    <h2 class="mt-8 text-[26px] font-normal leading-[1.2] text-[#1a2352] lg:mt-12 lg:text-[37px] xl:text-[42px]">{c.missionTitle}</h2>
    <p class="mt-6 max-w-[980px] text-[15px] leading-[1.4] text-[#1a2352] md:max-w-[calc(86vw_-_128px)] lg:mt-8 lg:text-[18px] xl:max-w-[980px]">{c.missionBody}</p>

    <div class="mt-10 flex w-full max-w-[900px] flex-wrap justify-center gap-3 lg:mt-16 lg:gap-4">
      {valueNames.map((name, i) => (
        <div class="flex w-full max-w-[520px] flex-col items-center justify-center gap-1 rounded-full bg-gradient-to-b from-[#e9f0f9] to-white px-6 py-4 sm:w-[31%] sm:max-w-[280px] lg:py-5">
          <h3 class="text-[18px] font-normal text-[#1a2352] lg:text-[22px]">{name}</h3>
          <p class="text-[16px] leading-[1.4] text-[#1a2352] md:text-[18px]">{c.valueDescs[i]}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Ethical AI pillars -->
<section class="bg-white">
  <div class="container-c pb-14 lg:pb-24">
    <div class="mx-auto max-w-[860px] text-left sm:text-center md:max-w-[calc(67vw_+_48px)] xl:max-w-[911px]">
      <h2 class="text-[26px] font-normal leading-[1.2] text-[#1a2352] lg:text-[37px] xl:text-[43px]">{c.ethicalTitle}</h2>
      <p class="mt-5 text-[15px] leading-[1.4] text-[#1a2352] lg:text-[18px]">{c.ethicalSubtitle}</p>
    </div>
    <div class="mx-auto mt-10 grid max-w-[1120px] gap-4 md:grid-cols-2 lg:mt-14 lg:gap-6">
      {c.pillars.map((p) => (
        <div class="rounded-2xl bg-[#f3f8ff] px-6 py-5 lg:min-h-[220px] lg:px-7 lg:py-10">
          <h3 class="text-[20px] font-normal text-[#1a2352] xl:text-[22px]">{p.title}</h3>
          <p class="mt-3 text-[14px] leading-[1.4] text-[#1a2352] lg:text-[15px]">{p.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Contact — info on the left, embedded office map on the right (as on the
     original site). -->
<section class="bg-[#f4f5f7]">
  <div class="container-c grid items-start gap-10 py-12 md:grid-cols-2 md:gap-10 lg:gap-14 lg:py-14">
    <div>
      <h2 class="font-body text-[32px] font-semibold leading-[1.2] text-[#1a2352] lg:text-[46px]">{c.contactLabel}</h2>
      <address class="mt-8 space-y-1.5 text-[16px] not-italic text-[#1a2352] md:text-[18px]">
        <p class="text-[18px] lg:text-[20px]">{c.locationLabel}</p>
        <p>{c.address}</p>
        <p><a href={`mailto:${contact.email}`} class="hover:text-brand">{contact.email}</a></p>
        <p><a href="tel:+82-2-6925-6978" class="hover:text-brand">{c.phone}</a></p>
      </address>
      <div class="mt-7 lg:hidden">
        <a href={MAP_URL} target="_blank" rel="noopener" class="btn-pill border-transparent bg-brand-ink font-semibold text-white hover:bg-[#035a9a]">{cl.map}</a>
      </div>
    </div>
    <iframe
      src={MAP_EMBED(mapLang[lang])}
      title={cl.mapTitle}
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen
      class="h-[240px] w-full md:h-[320px] md:rounded-2xl md:border md:border-black/10 lg:h-[380px]"
    ></iframe>
  </div>
</section>
