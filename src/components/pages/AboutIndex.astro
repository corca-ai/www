---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/ui';
import { localizePath } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// News/Colleagues sections mirror their pages' live content: the latest news
// item (image + headline + date) and the first colleague on the page (photo +
// role + quote), so this landing never goes stale when content is added.
const asDate = (d: string) => new Date(d.replace(/\//g, '-')).getTime();
// Both collections are always non-empty (the build fails on an empty locale),
// so the first entry is guaranteed to exist.
const latestNews = (await getCollection('news')).map((e) => e.data).sort((a, b) => asDate(b.date) - asDate(a.date))[0]!;
const firstColleague = (await getCollection('colleagues')).map((e) => e.data).sort((a, b) => a.order - b.order)[0]!;

// Company category landing (issue #33): links to the four About sub-pages.
const dict = {
  ko: {
    title: '회사 소개',
    sub: '코르카의 비전과 미션, 일하는 방식, 그리고 함께하는 사람들을 소개합니다.',
    cta: '자세히 보기',
    items: [
      { name: '비전과 미션', slug: '/about/vision-mission', body: '상상을 현실로 바꾸는 AI 기술. 코르카가 그리는 비전과 미션.' },
      { name: '이렇게 일해요', slug: '/about/how-we-work', body: 'AI 네이티브 조직 코르카가 실제로 일하는 방식과 문화.' },
      { name: '뉴스 기사', slug: '/news', body: '언론이 주목한 코르카의 성과와 소식 모음.' },
      { name: '코르카 사람들', slug: '/about/colleagues', body: '코르카를 만들어가는 사람들과 팀 문화 이야기.' },
    ],
  },
  en: {
    title: 'About',
    sub: 'Corca’s vision and mission, how we work, and the people behind it all.',
    cta: 'Learn more',
    items: [
      { name: 'Vision & Mission', slug: '/about/vision-mission', body: 'AI that turns imagination into reality — the vision and mission Corca pursues.' },
      { name: 'How We Work', slug: '/about/how-we-work', body: 'How Corca, an AI-native organization, actually works — our culture and practices.' },
      { name: 'News', slug: '/news', body: 'Corca’s achievements and news, as covered by the press.' },
      { name: 'Our People', slug: '/about/colleagues', body: 'The people who build Corca and the story of our team culture.' },
    ],
  },
  ja: {
    title: '会社紹介',
    sub: 'コルカのビジョンとミッション、働き方、そして共に働く人々をご紹介します。',
    cta: '詳しく見る',
    items: [
      { name: 'ビジョンとミッション', slug: '/about/vision-mission', body: '想像を現実に変えるAI技術。コルカが描くビジョンとミッション。' },
      { name: '私たちの働き方', slug: '/about/how-we-work', body: 'AIネイティブ組織コルカが実際に働く方法と文化。' },
      { name: 'ニュース', slug: '/news', body: 'メディアが注目したコルカの成果とお知らせ。' },
      { name: 'コルカの人々', slug: '/about/colleagues', body: 'コルカをつくる人々とチーム文化の物語。' },
    ],
  },
  zh: {
    title: '公司介绍',
    sub: '为你介绍Corca的愿景与使命、工作方式，以及并肩同行的伙伴们。',
    cta: '了解更多',
    items: [
      { name: '愿景与使命', slug: '/about/vision-mission', body: '将想象变为现实的AI技术——Corca描绘的愿景与使命。' },
      { name: '我们的工作方式', slug: '/about/how-we-work', body: 'AI原生组织Corca实际的工作方式与文化。' },
      { name: '新闻报道', slug: '/news', body: '媒体关注的Corca成果与最新动态。' },
      { name: 'Corca 的伙伴们', slug: '/about/colleagues', body: '打造Corca的人们与团队文化的故事。' },
    ],
  },
};
const c = dict[lang];

const IMAGE_ALT: Record<Lang, Record<string, string>> = {
  ko: {
    '/about/vision-mission': '코르카의 비전과 미션을 표현한 이미지',
    '/about/how-we-work': '코르카 팀이 AX Day에서 함께 일하는 모습',
    '/news': `${latestNews.title.ko} 기사 대표 이미지`,
    '/about/colleagues': `${firstColleague.role.ko} 인터뷰 사진`,
  },
  en: {
    '/about/vision-mission': 'Visual representing Corca’s vision and mission',
    '/about/how-we-work': 'Corca team members working together during AX Day',
    '/news': `Featured image for “${latestNews.title.en}”`,
    '/about/colleagues': `Interview portrait of ${firstColleague.role.en}`,
  },
  ja: {
    '/about/vision-mission': 'Corcaのビジョンとミッションを表すイメージ',
    '/about/how-we-work': 'AX Dayで共に働くCorcaチームの様子',
    '/news': `「${latestNews.title.ja}」の記事画像`,
    '/about/colleagues': `${firstColleague.role.ja}のインタビュー写真`,
  },
  zh: {
    '/about/vision-mission': '展现Corca愿景与使命的图片',
    '/about/how-we-work': 'Corca团队在AX Day协作的场景',
    '/news': `《${latestNews.title.zh}》的文章配图`,
    '/about/colleagues': `${firstColleague.role.zh}的采访照片`,
  },
};

// Representative image per sub-page. vision-mission/how-we-work are fixed
// (hero bg, AX Day office photo); news/colleagues come from the collections
// above so they follow the latest content automatically.
const IMAGES: Record<string, string> = {
  '/about/vision-mission': '/images/pages/2fe9a6_d35d2743fc2342df884222c5a0d125ee.webp',
  '/about/how-we-work': '/images/pages/ax-day.webp',
  '/news': `/images/pages/${latestNews.image}.webp`,
  '/about/colleagues': `/images/pages/${firstColleague.image}.webp`,
};

// Live headline + secondary line pulled from the linked page's newest content.
const EXTRA: Record<string, { title: string; meta: string } | undefined> = {
  '/news': { title: latestNews.title[lang], meta: latestNews.date },
  '/about/colleagues': { title: firstColleague.role[lang], meta: firstColleague.quote[lang] },
};
---

<section class="bg-gradient-to-b from-[#e1eaf7] to-white">
  <div class="container-c pb-9 pt-11 text-center md:pb-10 md:pt-16">
    <h1 class="font-body text-[26px] font-normal leading-[1.2] text-[#1a2352] md:text-[32px] lg:text-[44px] xl:text-[51px]">{c.title}</h1>
    <p class="mx-auto mt-3 max-w-[720px] text-[15px] leading-[1.4] text-[#1a2352] md:text-[18px]">{c.sub}</p>
  </div>
</section>

<!-- Same alternating showcase layout as the /products landing: image and copy
     side by side, image side and section background alternating per item. -->
{c.items.map((it, i) => (
  <section class={i % 2 === 1 ? 'bg-[#f3f8ff]' : 'bg-white'}>
    <div class="container-c grid items-center gap-10 py-10 md:grid-cols-2 md:gap-16 lg:py-16">
      <div class={i % 2 === 1 ? 'order-first md:order-last' : 'order-first'}>
        <img
          src={IMAGES[it.slug]}
          alt={IMAGE_ALT[lang][it.slug]}
          width="900"
          height="620"
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
          class="aspect-[16/10] w-full rounded-2xl object-cover object-center shadow-[var(--shadow-card)] md:aspect-[16/9]"
        />
      </div>
      <div>
        <h2 class="text-[26px] font-normal leading-[1.2] text-heading md:text-[28px] lg:text-[32px]">{it.name}</h2>
        <p class="mt-5 text-[16px] leading-[1.4] text-heading lg:text-[18px]">{it.body}</p>
        {EXTRA[it.slug] && (
          <div class="mt-4 border-l-2 border-brand-ink/30 pl-4">
            <p class="text-[16px] font-semibold leading-[1.4] text-heading">{EXTRA[it.slug]!.title}</p>
            <p class="mt-1 line-clamp-2 text-[14px] leading-[1.5] text-ink-soft">{EXTRA[it.slug]!.meta}</p>
          </div>
        )}
        <a href={localizePath(it.slug, lang)} class="btn-pill btn-pill-dark mt-8">{c.cta}</a>
      </div>
    </div>
  </section>
))}
