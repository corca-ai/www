---
import type { Lang } from '../../i18n/ui';
import { localizePath } from '../../i18n/utils';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Company category landing (issue #33): links to the four About sub-pages.
const dict = {
  ko: {
    title: '회사 소개',
    sub: '코르카의 비전과 미션, 일하는 방식, 그리고 함께하는 사람들을 소개합니다.',
    cta: '자세히 보기',
    items: [
      { name: '비전과 미션', slug: '/about/vision-mission', body: '상상을 현실로 바꾸는 AI 기술. 코르카가 그리는 비전과 미션.' },
      { name: '이렇게 일해요', slug: '/about/how-we-work', body: 'AI 네이티브 조직 코르카가 실제로 일하는 방식과 문화.' },
      { name: '뉴스 기사', slug: '/news', body: '언론이 주목한 코르카의 성과와 소식 모음.' },
      { name: '코르카 사람들', slug: '/about/colleagues', body: '코르카를 만들어가는 사람들과 팀 문화 이야기.' },
    ],
  },
  en: {
    title: 'About',
    sub: 'Corca’s vision and mission, how we work, and the people behind it all.',
    cta: 'Learn more',
    items: [
      { name: 'Vision & Mission', slug: '/about/vision-mission', body: 'AI that turns imagination into reality — the vision and mission Corca pursues.' },
      { name: 'How We Work', slug: '/about/how-we-work', body: 'How Corca, an AI-native organization, actually works — our culture and practices.' },
      { name: 'News', slug: '/news', body: 'Corca’s achievements and news, as covered by the press.' },
      { name: 'Our People', slug: '/about/colleagues', body: 'The people who build Corca and the story of our team culture.' },
    ],
  },
  ja: {
    title: '会社紹介',
    sub: 'コルカのビジョンとミッション、働き方、そして共に働く人々をご紹介します。',
    cta: '詳しく見る',
    items: [
      { name: 'ビジョンとミッション', slug: '/about/vision-mission', body: '想像を現実に変えるAI技術。コルカが描くビジョンとミッション。' },
      { name: '私たちの働き方', slug: '/about/how-we-work', body: 'AIネイティブ組織コルカが実際に働く方法と文化。' },
      { name: 'ニュース', slug: '/news', body: 'メディアが注目したコルカの成果とお知らせ。' },
      { name: 'コルカの人々', slug: '/about/colleagues', body: 'コルカをつくる人々とチーム文化の物語。' },
    ],
  },
  zh: {
    title: '公司介绍',
    sub: '为你介绍Corca的愿景与使命、工作方式，以及并肩同行的伙伴们。',
    cta: '了解更多',
    items: [
      { name: '愿景与使命', slug: '/about/vision-mission', body: '将想象变为现实的AI技术——Corca描绘的愿景与使命。' },
      { name: '我们的工作方式', slug: '/about/how-we-work', body: 'AI原生组织Corca实际的工作方式与文化。' },
      { name: '新闻报道', slug: '/news', body: '媒体关注的Corca成果与最新动态。' },
      { name: 'Corca 的伙伴们', slug: '/about/colleagues', body: '打造Corca的人们与团队文化的故事。' },
    ],
  },
};
const c = dict[lang];
---

<section class="bg-gradient-to-b from-[#e1eaf7] to-white">
  <div class="container-c pb-8 pt-10 text-center lg:pt-24">
    <h1 class="font-body text-[26px] font-normal leading-[1.2] text-[#1a2352] md:text-[32px] lg:text-[44px] xl:text-[51px]">{c.title}</h1>
    <p class="mx-auto mt-3 max-w-[720px] text-[15px] leading-[1.4] text-[#1a2352] md:text-[18px]">{c.sub}</p>
  </div>
</section>

<section class="bg-white">
  <div class="container-c grid gap-4 pb-16 pt-8 md:grid-cols-2 lg:gap-6 lg:pb-24 lg:pt-10">
    {c.items.map((it) => (
      <a
        href={localizePath(it.slug, lang)}
        class="group flex flex-col rounded-2xl bg-[#f3f8ff] px-6 py-7 lg:px-8 lg:py-9"
      >
        <h2 class="font-body text-[20px] font-semibold text-[#1a2352] lg:text-[24px]">{it.name}</h2>
        <p class="mt-3 flex-1 text-[15px] leading-[1.5] text-[#1a2352]/80 lg:text-[16px]">{it.body}</p>
        <span class="mt-5 inline-flex items-center gap-1 text-[14px] font-medium text-brand-ink">
          {c.cta}
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M6 3.5 10.5 8 6 12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
      </a>
    ))}
  </div>
</section>
