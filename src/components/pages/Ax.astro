---
import type { Lang } from '../../i18n/ui';
import AxLegacy from './AxLegacy.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<!--
  The current AX implementation is intentionally wrapped so `/ax-backup` can
  keep the approved 2026-07-22 snapshot when `/ax` moves to its next design.
  Replace this wrapper with a new component during the redesign; do not edit
  AxLegacy.astro or components/pages/ax solely to change the new page.
-->
<AxLegacy lang={lang} />
