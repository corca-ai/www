---
import type { Lang } from '../../i18n/ui';
import AxLeadForm from './ax-v2/AxLeadForm.astro';
import AxLines from './ax-v2/AxLines.astro';
import AxResponsiveLines from './ax-v2/AxResponsiveLines.astro';
import { axV2Assets, axV2ContentByLang } from './ax-v2/content';
import './ax-v2/ax-v2.css';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const c = axV2ContentByLang[lang];
const slowdownGradientStart = lang === 'ja' ? 1 : 2;
const uiCopy = {
  ko: {
    compoundAlt: '맑은 아침의 푸른 대서양을 활기차게 유영하는 열 마리 범고래 무리',
    testimonials: '고객 후기',
    carousel: '고객 후기 이동',
    previous: '이전 고객 후기',
    next: '다음 고객 후기',
    clientLogos: 'Corca AX와 함께한 고객사 로고',
    executionAreas: 'Corca AX 실행 영역',
    cealIntroduction: 'Ceal 도입',
    onPremises: '온프레미스로 설치',
    openAiCorcaAlt: 'OpenAI와 Corca 로고',
    dialogClose: '상담 신청 창 닫기',
    successEyebrow: '상담 접수 완료',
    successTitle: '상담 신청이 접수되었습니다.',
    successBody: ['보내주신 내용을 담당자가 꼼꼼히 확인한 뒤 곧 연락드리겠습니다.', '감사합니다.', '이 창은 잠시 후 자동으로 닫힙니다.'],
    close: '닫기',
  },
  en: {
    compoundAlt: 'Ten orcas swimming across the blue Atlantic on a clear morning',
    testimonials: 'Client testimonials',
    carousel: 'Navigate client testimonials',
    previous: 'Previous testimonial',
    next: 'Next testimonial',
    clientLogos: 'Organizations working with Corca AX',
    executionAreas: 'Corca AX execution areas',
    cealIntroduction: 'Introduce Ceal',
    onPremises: 'On-premises',
    openAiCorcaAlt: 'OpenAI and Corca logos',
    dialogClose: 'Close consultation form',
    successEyebrow: 'Request received',
    successTitle: 'Your consultation request is complete.',
    successBody: ['Our team will review your message carefully and contact you soon.', 'Thank you.', 'This window will close automatically.'],
    close: 'Close',
  },
  ja: {
    compoundAlt: '晴れた朝の青い大西洋を泳ぐ10頭のシャチ',
    testimonials: 'お客様の声',
    carousel: 'お客様の声を移動',
    previous: '前のお客様の声',
    next: '次のお客様の声',
    clientLogos: 'Corca AXをご利用のお客様',
    executionAreas: 'Corca AXの実行領域',
    cealIntroduction: 'Ceal導入',
    onPremises: 'オンプレミス設置',
    openAiCorcaAlt: 'OpenAIとCorcaのロゴ',
    dialogClose: '相談フォームを閉じる',
    successEyebrow: '受付完了',
    successTitle: '相談申請を受け付けました。',
    successBody: ['担当者が内容を確認し、まもなくご連絡します。', 'ありがとうございます。', 'この画面は自動的に閉じます。'],
    close: '閉じる',
  },
  zh: {
    compoundAlt: '十头虎鲸在晴朗清晨的蓝色大西洋中畅游',
    testimonials: '客户评价',
    carousel: '浏览客户评价',
    previous: '上一条评价',
    next: '下一条评价',
    clientLogos: '与Corca AX合作的客户',
    executionAreas: 'Corca AX执行领域',
    cealIntroduction: '引入Ceal',
    onPremises: '本地部署',
    openAiCorcaAlt: 'OpenAI与Corca标志',
    dialogClose: '关闭咨询表单',
    successEyebrow: '申请已受理',
    successTitle: '您的咨询申请已提交。',
    successBody: ['负责人将认真查看您的信息并尽快与您联系。', '感谢您的咨询。', '此窗口将自动关闭。'],
    close: '关闭',
  },
}[lang];

---

<div class="ax-v2-page" data-ax-v2-page>
  <section class="ax-v2-hero" id="ax-top" aria-labelledby="ax-v2-hero-title">
    <img
      class="ax-v2-partner-badge"
      src={axV2Assets.partnerNetwork}
      width="100"
      height="115"
      alt="OpenAI Select Partner"
    />
    <div class="ax-v2-hero-media is-video-reset" data-hero-media aria-hidden="true">
      <picture class="ax-v2-hero-poster">
        <source media="(max-width: 720px)" type="image/avif" srcset={axV2Assets.hero.mobileAvif} />
        <source media="(max-width: 720px)" type="image/webp" srcset={axV2Assets.hero.mobileWebp} />
        <source type="image/avif" srcset={axV2Assets.hero.wideAvif} />
        <source type="image/webp" srcset={axV2Assets.hero.wideWebp} />
        <img
          src={axV2Assets.hero.wideWebp}
          width="1586"
          height="992"
          alt=""
          fetchpriority="high"
          loading="eager"
        />
      </picture>
      <video data-hero-video muted loop playsinline preload="none" disablepictureinpicture tabindex="-1">
        <source data-src={axV2Assets.hero.video} type="video/webm" />
      </video>
    </div>
    <div class="ax-v2-hero-copy ax-v2-shell" data-reveal>
      <h1 id="ax-v2-hero-title">{c.hero.h1}</h1>
      <h2>
        {c.hero.h2.map((segments, index) => (
          <>
            {index > 0 && <br />}
            <span class:list={{ 'ax-v2-gradient-text': index === 1 }}>
              {segments.map((segment, segmentIndex) => (
                <>
                  {segmentIndex > 0 && <><br class="ax-v2-hero-h2-break--compact" />{' '}</>}
                  {segment}
                </>
              ))}
            </span>
          </>
        ))}
      </h2>
      <h3>
        {c.hero.h3.map((line, index) => (
          <>
            {index > 0 && <><br class={index === 3 ? 'ax-v2-hero-h3-break--tablet-hidden' : undefined} />{' '}</>}
            {line}
          </>
        ))}
      </h3>
      <button class="ax-v2-primary-button" type="button" data-contact-jump>{c.hero.cta}</button>
    </div>
  </section>

  <section class="ax-v2-section ax-v2-proof-section" aria-labelledby="ax-v2-transformation-title">
    <div class="ax-v2-shell">
      <h2 class="ax-v2-eyebrow" data-reveal>{c.transformation.eyebrow}</h2>
      <div class="ax-v2-heading-block" data-reveal>
        <h3 id="ax-v2-transformation-title">
          <span>{c.transformation.heading[0]}</span><br />
          <span class="ax-v2-point-gradient">{c.transformation.heading[1]}</span>
        </h3>
        <p class="ax-v2-lead ax-v2-spaced-lines">
          <span>{c.transformation.lead[0]}</span><br />
          <strong>{c.transformation.lead[1]}</strong>
        </p>
        <p><AxLines values={c.transformation.body} /></p>
      </div>

      <div class="ax-v2-testimonials" role="region" aria-label={uiCopy.testimonials} tabindex="0" data-testimonial-carousel>
        <div class="ax-v2-testimonial-track" data-testimonial-track>
          {c.transformation.testimonials.map((item, index) => {
            const logo = axV2Assets.testimonials[item.id];
            return (
              <figure
                class="ax-v2-testimonial-card"
                data-testimonial-slide
                data-carousel-slide
                data-carousel-announcement={`${index + 1} / ${c.transformation.testimonials.length} — ${item.source}`}
                data-slide-label={`${index + 1} / ${c.transformation.testimonials.length} — ${item.source}`}
                data-testimonial-highlight-card={item.highlights.length > 0 ? '' : undefined}
                aria-labelledby={`ax-v2-testimonial-source-${index + 1}`}
              >
                <blockquote>
                  {item.quote.map((line, lineIndex) => {
                    const highlightIndex = item.highlights.findIndex(({ start }) => start === lineIndex);
                    const highlight = highlightIndex >= 0 ? item.highlights[highlightIndex] : undefined;
                    const isCoveredByEarlierHighlight = item.highlights.some(
                      ({ start, end }) => lineIndex > start && lineIndex <= end,
                    );
                    if (isCoveredByEarlierHighlight) return null;
                    return (
                      <>
                        {lineIndex > 0 && <br />}
                        {highlight ? (
                          <mark
                            class="ax-v2-testimonial-highlight"
                            data-highlight-order={highlightIndex + 1}
                          >
                            {item.quote.slice(highlight.start, highlight.end + 1).map((highlightLine, offset) => (
                              <>{offset > 0 && <br />}{highlightLine}</>
                            ))}
                          </mark>
                        ) : line}
                      </>
                    );
                  })}
                </blockquote>
                <figcaption>
                  <picture>
                    <source type="image/webp" srcset={logo.webp} />
                    <img
                      src={logo.png}
                      width={logo.width}
                      height={logo.height}
                      alt={item.logoAlt}
                      loading="lazy"
                      decoding="async"
                    />
                  </picture>
                  <h4 id={`ax-v2-testimonial-source-${index + 1}`}>{item.source}</h4>
                </figcaption>
              </figure>
            );
          })}
        </div>
        <div class="ax-v2-carousel-footer">
          <p class="ax-v2-carousel-status ax-v2-visually-hidden" role="status" aria-live="polite" aria-atomic="true" data-carousel-status>
            1 / {c.transformation.testimonials.length} — {c.transformation.testimonials[0].source}
          </p>
          <div class="ax-v2-carousel-controls" aria-label={uiCopy.carousel}>
            <button type="button" aria-label={uiCopy.previous} data-carousel-previous disabled>←</button>
            <button type="button" aria-label={uiCopy.next} data-carousel-next>→</button>
          </div>
        </div>
      </div>

      <p class="ax-v2-proof-statement" data-reveal>{c.transformation.proof}</p>
    </div>

    <div class="ax-v2-logo-marquee" role="img" aria-label={uiCopy.clientLogos}>
      <div class="ax-v2-logo-track">
        {[0, 1].map((copyIndex) => (
          <div class="ax-v2-logo-group" aria-hidden="true" data-copy={copyIndex}>
            {axV2Assets.organizations.map((logo) => (
              <picture>
                <source type="image/webp" srcset={logo.webp} />
                <img src={logo.png} width={logo.width} height={logo.height} alt="" loading="lazy" decoding="async" />
              </picture>
            ))}
          </div>
        ))}
      </div>
    </div>
    <p class="ax-v2-disclaimer">{c.transformation.disclaimer}</p>
  </section>

  <section class="ax-v2-section ax-v2-blue-wash" aria-labelledby="ax-v2-internal-title">
    <div class="ax-v2-shell">
      <h2 class="ax-v2-eyebrow" data-reveal>{c.internalProof.eyebrow}</h2>
      <div class="ax-v2-heading-block" data-reveal>
        <h3 id="ax-v2-internal-title">
          {c.internalProof.heading.map((line, index) => (
            <>{index > 0 && <br />}<span class:list={{ 'ax-v2-point-gradient': index === 1 }}>{line}</span></>
          ))}
        </h3>
        <p><AxLines values={c.internalProof.body} /></p>
      </div>
      <div class="ax-v2-internal-sequence" data-internal-proof-sequence>
        <div class="ax-v2-circle-grid">
          {c.internalProof.cards.map((card) => (
            <article class="ax-v2-circle-card">
              <span>{card.cadence}</span>
              <h4 class="ax-v2-point-gradient">{card.title}</h4>
              <strong>{card.lead}</strong>
              <p><AxLines values={card.body} /></p>
            </article>
          ))}
        </div>
        <div class="ax-v2-press-row">
          <p>{c.internalProof.pressLead}</p>
          <a class="ax-v2-text-link" href={c.internalProof.pressUrl} target="_blank" rel="noreferrer">
            {c.internalProof.pressLabel}<span aria-hidden="true"> ↗</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="ax-v2-section ax-v2-dark-section" aria-labelledby="ax-v2-slowdown-title">
    <div class="ax-v2-shell">
      <h2 class="ax-v2-eyebrow" data-reveal>{c.slowdown.eyebrow}</h2>
      <div class="ax-v2-heading-block ax-v2-heading-block-wide" data-reveal>
        <h3 id="ax-v2-slowdown-title">
          {c.slowdown.heading.map((segments, index) => (
            <>
              {index > 0 && <br />}
              <span class:list={{ 'ax-v2-point-gradient': index >= slowdownGradientStart }}>
                {segments.map((segment, segmentIndex) => (
                  <>
                    {segmentIndex > 0 && (
                      <>
                        <span class="ax-v2-slowdown-desktop-space"> </span>
                        <br class="ax-v2-slowdown-mobile-break" />
                      </>
                    )}
                    {segment}
                  </>
                ))}
              </span>
            </>
          ))}
        </h3>
        <p><AxLines values={c.slowdown.body} /></p>
        <strong class="ax-v2-section-closing"><AxLines values={c.slowdown.closing} /></strong>
      </div>

      <div class="ax-v2-split-tabs" data-ax-v2-tabs>
        <div class="ax-v2-tab-list" role="tablist" aria-label={uiCopy.executionAreas}>
          {c.slowdown.tabs.map((tab, index) => (
            <button
              type="button"
              role="tab"
              id={`ax-v2-tab-${tab.id}`}
              aria-controls={`ax-v2-panel-${tab.id}`}
              aria-selected={index === 0 ? 'true' : 'false'}
              tabindex={index === 0 ? '0' : '-1'}
              data-tab-button
            >
              <span aria-hidden="true">{String(index + 1).padStart(2, '0')}</span>
              {tab.title}
            </button>
          ))}
        </div>
        <div class="ax-v2-tab-panels">
          {c.slowdown.tabs.map((tab, index) => (
            <article
              role="tabpanel"
              id={`ax-v2-panel-${tab.id}`}
              aria-labelledby={`ax-v2-tab-${tab.id}`}
              aria-hidden={index === 0 ? 'false' : 'true'}
              data-tab-panel
            >
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h4>{tab.title}</h4>
              <strong>{tab.subtitle}</strong>
              <p>{tab.body}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="ax-v2-accordion" data-ax-v2-accordion>
        {c.slowdown.tabs.map((tab, index) => (
          <div class="ax-v2-accordion-item">
            <h4>
              <button
                type="button"
                aria-expanded={index === 0 ? 'true' : 'false'}
                aria-controls={`ax-v2-accordion-panel-${tab.id}`}
                data-accordion-button
              >
                <span>{String(index + 1).padStart(2, '0')}</span>{tab.title}<i aria-hidden="true">＋</i>
              </button>
            </h4>
            <div id={`ax-v2-accordion-panel-${tab.id}`} data-accordion-panel hidden={index !== 0}>
              <strong>{tab.subtitle}</strong>
              <p>{tab.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="ax-v2-section ax-v2-diagnosis-section" aria-labelledby="ax-v2-diagnosis-title">
    <div class="ax-v2-shell">
      <h2 class="ax-v2-eyebrow" data-reveal>{c.diagnosis.eyebrow}</h2>
      <div class="ax-v2-heading-block" data-reveal>
        <h3 id="ax-v2-diagnosis-title">
          {c.diagnosis.heading.map((line, index) => (
            <>{index > 0 && <br />}<span class:list={{ 'ax-v2-point-gradient': index === 1 }}>{line}</span></>
          ))}
        </h3>
        <div class="ax-v2-metric"><strong class="ax-v2-point-gradient">{c.diagnosis.metric[0]}</strong><span>{c.diagnosis.metric[1]}</span></div>
        <p><AxLines values={c.diagnosis.body} /></p>
      </div>
      <div class="ax-v2-diagnosis-sequence" data-diagnosis-sequence>
        <div class="ax-v2-comparison">
          <article class="ax-v2-comparison-legacy">
            <h4><AxLines values={c.diagnosis.legacy.title} /></h4>
            <p>{c.diagnosis.legacy.bodyLines.length > 0 ? <AxLines values={c.diagnosis.legacy.bodyLines} /> : c.diagnosis.legacy.body}</p>
            <ul>{c.diagnosis.legacy.items.map((item) => {
              const [count, ...label] = item.split(' ');
              return <li><strong>{count}</strong><span>{label.join(' ')}</span></li>;
            })}</ul>
          </article>
          <span class="ax-v2-comparison-arrow" aria-hidden="true">➜</span>
          <article class="ax-v2-comparison-corca">
            <h4><AxLines values={c.diagnosis.corca.title} /></h4>
            <p><AxLines values={c.diagnosis.corca.body} /></p>
            <ol>{c.diagnosis.corca.items.map((item) => {
              const [count, ...label] = item.split(' ');
              return <li><strong>{count}</strong><span>{label.join(' ')}</span></li>;
            })}</ol>
          </article>
        </div>
        <strong class="ax-v2-section-closing ax-v2-dark-closing"><AxLines values={c.diagnosis.closing} /></strong>
        <p class="ax-v2-source-note">{c.diagnosis.note}</p>
      </div>
    </div>
  </section>

  <section
    class="ax-v2-section ax-v2-blue-wash ax-v2-coaching-section"
    aria-labelledby="ax-v2-coaching-title"
    data-coaching-parallax
  >
    <div class="ax-v2-coaching-parallax-bg" aria-hidden="true"></div>
    <div class="ax-v2-shell ax-v2-coaching-content">
      <h2 class="ax-v2-eyebrow" data-reveal>{c.coaching.eyebrow}</h2>
      <div class="ax-v2-heading-block" data-reveal>
        <h3 id="ax-v2-coaching-title">
          {c.coaching.heading.map((line, index) => (
            <>{index > 0 && <br />}<span class:list={{ 'ax-v2-point-gradient': index === 1 }}>{line}</span></>
          ))}
        </h3>
        <p><AxResponsiveLines lines={c.coaching.body} mobileMergeBefore={[3]} /></p>
      </div>
      <div class="ax-v2-card-grid">
        {c.coaching.cards.map((card) => (
          <article class="ax-v2-feature-card" data-reveal>
            <h4>{card.title}</h4>
            <strong class="ax-v2-point-gradient"><AxLines values={card.lead} /></strong>
            <p><AxLines values={card.body} /></p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="ax-v2-section ax-v2-environment-section" aria-labelledby="ax-v2-environment-title">
    <div class="ax-v2-shell">
      <h2 class="ax-v2-eyebrow" data-reveal>{c.environment.eyebrow}</h2>
      <div class="ax-v2-heading-block ax-v2-heading-block-wide ax-v2-heading-block-centered" data-reveal>
        <h3 id="ax-v2-environment-title">
          <AxResponsiveLines lines={c.environment.heading} gradientFrom={2} />
        </h3>
        <p>
          {c.environment.body.map((line, index) => {
            const [beforeEmphasis, afterEmphasis] = line.split(c.environment.bodyEmphasis);
            return (
              <>
                {index > 0 && <br />}
                {beforeEmphasis}
                {afterEmphasis !== undefined && (
                  <><strong>{c.environment.bodyEmphasis}</strong>{afterEmphasis}</>
                )}
              </>
            );
          })}
        </p>
      </div>
      <div class="ax-v2-environment-table" data-reveal>
        <table>
          <thead><tr>{c.environment.columns.map((column) => <th scope="col">{column}</th>)}</tr></thead>
          <tbody>
            {c.environment.rows.map((row) => (
              <tr>
                <th scope="row"><strong>{row.title}</strong><span>{row.english}</span></th>
                <td><span>{row.symptom}</span><span class="ax-v2-table-arrow" aria-hidden="true"></span></td>
                <td>{row.risk}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="ax-v2-environment-cards">
        {c.environment.rows.map((row) => (
          <article>
            <h4>{row.title}<span>{row.english}</span></h4>
            <dl>
              <div><dt>{c.environment.columns[1]}</dt><dd>{row.symptom}</dd></div>
              <div><dt>{c.environment.columns[2]}</dt><dd>{row.risk}</dd></div>
            </dl>
          </article>
        ))}
      </div>
      <strong class="ax-v2-section-closing ax-v2-dark-closing"><AxLines values={c.environment.closing} /></strong>
    </div>
  </section>

  <section
    class="ax-v2-section ax-v2-dark-section ax-v2-ceal-section ax-v2-ceal-section-centered"
    aria-labelledby="ax-v2-ceal-title"
  >
    <div class="ax-v2-shell">
      <h2 class="ax-v2-eyebrow" data-reveal>{c.ceal.eyebrow}</h2>
      <div class="ax-v2-heading-block ax-v2-heading-block-centered" data-reveal>
        <h3 id="ax-v2-ceal-title">
          {c.ceal.heading.map((line, index) => (
            <>{index > 0 && <br />}<span class:list={{ 'ax-v2-point-gradient': index === 1 }}>{line}</span></>
          ))}
        </h3>
        <p><AxLines values={c.ceal.body} /></p>
      </div>
      <div class="ax-v2-ceal-diagrams" data-ceal-diagrams data-reveal>
        <figure class="ax-v2-ceal-before">
          <figcaption><strong>{c.ceal.before}</strong><span>{c.ceal.beforeBadge}</span></figcaption>
          <div class="ax-v2-ceal-node-row">{c.ceal.agents.map((agent) => <span>{agent}</span>)}</div>
          <div class="ax-v2-chaos-rails" aria-hidden="true">
            <i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i>
          </div>
          <div class="ax-v2-ceal-node-row">{c.ceal.systems.map((system) => <span>{system}</span>)}</div>
          <ul class="ax-v2-ceal-notes">{c.ceal.beforeNotes.map((note) => <li>{note}</li>)}</ul>
        </figure>
        <div class="ax-v2-ceal-transition" aria-hidden="true">
          <span>{uiCopy.cealIntroduction}</span><strong class="ax-v2-comparison-arrow">➜</strong>
        </div>
        <figure class="ax-v2-ceal-after">
          <figcaption><strong>{c.ceal.after}</strong><span>{c.ceal.afterBadge}</span></figcaption>
          <div class="ax-v2-ceal-node-row">{c.ceal.agents.map((agent) => <span>{agent}</span>)}</div>
          <div class="ax-v2-order-rails ax-v2-order-rails-top" aria-hidden="true">
            <i></i><i></i><i></i><i></i><i></i>
          </div>
          <strong class="ax-v2-ceal-gateway">{c.ceal.center}<small>{uiCopy.onPremises}</small></strong>
          <div class="ax-v2-order-rails ax-v2-order-rails-bottom" aria-hidden="true">
            <i></i><i></i><i></i><i></i><i></i>
          </div>
          <div class="ax-v2-ceal-node-row">{c.ceal.systems.map((system) => <span>{system}</span>)}</div>
          <ul class="ax-v2-ceal-notes">{c.ceal.afterNotes.map((note) => <li>{note}</li>)}</ul>
        </figure>
      </div>
      <div class="ax-v2-ceal-closing" data-reveal>
        <strong>{c.ceal.closing.slice(0, 3).join(' ')}</strong>
        <p>{c.ceal.closing[3]}</p>
      </div>
    </div>
  </section>

  <section class="ax-v2-section ax-v2-package-section" aria-labelledby="ax-v2-packages-title">
    <div class="ax-v2-shell">
      <h2 class="ax-v2-eyebrow" data-reveal>{c.packages.eyebrow}</h2>
      <div class="ax-v2-heading-block" data-reveal>
        <h3 id="ax-v2-packages-title">
          {c.packages.heading.map((line, index) => (
            <>{index > 0 && <br />}<span class:list={{ 'ax-v2-point-gradient': index === 1 }}>{line}</span></>
          ))}
        </h3>
      </div>
      <div class="ax-v2-package-grid">
        {c.packages.cards.map((card, index) => (
          <article
            class:list={['ax-v2-package-card', { 'is-featured': index === 1 }]}
            style={`--reveal-delay: ${index * 0.28}s`}
            data-reveal
          >
            <span>{card.name}</span>
            <h4>{card.title}</h4>
            <ul>{card.items.map((item) => <li>{item}</li>)}</ul>
          </article>
        ))}
      </div>
      <ul class="ax-v2-package-notes">{c.packages.notes.map((note) => <li>{note}</li>)}</ul>
    </div>
  </section>

  <section class="ax-v2-section ax-v2-partner-section" aria-labelledby="ax-v2-partner-title">
    <div class="ax-v2-shell ax-v2-partner-grid">
      <div data-reveal>
        <h2 class="ax-v2-eyebrow">{c.partner.eyebrow}</h2>
        <h3 id="ax-v2-partner-title">
          {c.partner.heading.map((line, index) => (
            <>{index > 0 && <br />}<span class:list={{ 'ax-v2-point-gradient': index === 1 }}>{line}</span></>
          ))}
        </h3>
        <p><AxLines values={c.partner.body} /></p>
        <a class="ax-v2-text-link" href={c.partner.pressUrl} target="_blank" rel="noreferrer">
          {c.partner.pressLabel}<span aria-hidden="true"> ↗</span>
        </a>
      </div>
      <picture class="ax-v2-partner-lockup" data-reveal>
        <source type="image/webp" srcset={axV2Assets.openAiCorca.webp} />
        <img
          src={axV2Assets.openAiCorca.png}
          width={axV2Assets.openAiCorca.width}
          height={axV2Assets.openAiCorca.height}
          alt={uiCopy.openAiCorcaAlt}
          loading="lazy"
          decoding="async"
        />
      </picture>
    </div>
  </section>

  <section
    class="ax-v2-section ax-v2-contact-section"
    id="ax-contact"
    aria-labelledby="ax-v2-contact-title"
    data-contact-section
  >
    <div class="ax-v2-shell ax-v2-contact-grid">
      <div class="ax-v2-contact-copy" data-reveal>
        <h2 id="ax-v2-contact-title">
          {c.contact.heading.map((line, index) => (
            <>
              {index > 0 && <br />}
              <span class:list={{ 'ax-v2-gradient-text': index >= Math.ceil(c.contact.heading.length / 2) }}>
                {line}
              </span>
            </>
          ))}
        </h2>
        <p><AxLines values={c.contact.body} /></p>
      </div>
      <div class="ax-v2-direct-contact" data-reveal>
        <p>{c.contact.directLead}</p>
        <a href={`mailto:${c.contact.email}`}>{c.contact.emailLabel}<strong>{c.contact.email}</strong></a>
        <a href="tel:+82269256978">{c.contact.phoneLabel}<strong>{c.contact.phone}</strong></a>
      </div>
      <div class="ax-v2-inline-form" data-reveal>
        <AxLeadForm id="inline" lang={lang} compact />
      </div>
    </div>
  </section>

  <section
    class="ax-v2-compound ax-v2-dark-section"
    aria-labelledby="ax-v2-compound-title"
    data-compound-parallax
  >
    <picture class="ax-v2-compound-media" data-compound-media>
      <source type="image/avif" srcset={axV2Assets.compoundOrcas.avif} />
      <source type="image/webp" srcset={axV2Assets.compoundOrcas.webp} />
      <img
        src={axV2Assets.compoundOrcas.jpg}
        width={axV2Assets.compoundOrcas.width}
        height={axV2Assets.compoundOrcas.height}
        alt={uiCopy.compoundAlt}
        loading="lazy"
        decoding="async"
      />
    </picture>
    <div class="ax-v2-shell ax-v2-compound-copy" data-compound-copy>
      <h2 id="ax-v2-compound-title">
        {c.compound.lines.map((line, index) => (
          <>
            {index > 0 && <br />}
            <span class={`ax-v2-compound-line ax-v2-compound-line-${index + 1}`}>{line}</span>
          </>
        ))}
      </h2>
    </div>
  </section>

  <dialog class="ax-v2-dialog" aria-labelledby="ax-v2-dialog-title" data-ax-v2-dialog>
    <div class="ax-v2-dialog-panel">
      <button class="ax-v2-dialog-close" type="button" aria-label={uiCopy.dialogClose} data-dialog-close>
        <span aria-hidden="true">×</span>
      </button>
      <div class="ax-v2-dialog-heading">
        <p class="ax-v2-dialog-title" id="ax-v2-dialog-title"><AxLines values={c.contact.heading} /></p>
        <p class="ax-v2-dialog-description">
          {c.contact.dialogBody.lead}<br />
          {c.contact.dialogBody.selection}<br class="ax-v2-dialog-desktop-break" /><span
            class="ax-v2-dialog-mobile-space"> </span
          >{c.contact.dialogBody.constraint}<br />
          {c.contact.dialogBody.route}<br />
          {c.contact.dialogBody.next}
        </p>
      </div>
      <AxLeadForm id="modal" lang={lang} compact />
    </div>
  </dialog>

  <dialog class="ax-v2-hold-dialog" aria-labelledby="ax-v2-hold-title" data-ax-v2-success-dialog>
    <div class="ax-v2-hold-panel">
      <div class="ax-v2-success-icon" aria-hidden="true">✓</div>
      <p class="ax-v2-eyebrow">{uiCopy.successEyebrow}</p>
      <p class="ax-v2-hold-title" id="ax-v2-hold-title">{uiCopy.successTitle}</p>
      <p class="ax-v2-hold-copy">
        {uiCopy.successBody.map((line) => <>{line}<br /></>)}
      </p>
      <div class="ax-v2-success-timer" aria-hidden="true"><span></span></div>
      <button class="ax-v2-primary-button" type="button" data-ax-v2-success-close>{uiCopy.close}</button>
    </div>
  </dialog>
</div>

<script is:inline>
  (() => {
    const bindContactJump = () => {
      const page = document.querySelector('[data-ax-v2-page]');
      const button = page?.querySelector('[data-contact-jump]');
      const contactSection = page?.querySelector('[data-contact-section]');
      if (!(button instanceof HTMLButtonElement) || !(contactSection instanceof HTMLElement)) return;
      if (button.dataset.contactJumpBound === 'true') return;

      button.dataset.contactJumpBound = 'true';
      button.addEventListener('click', () => {
        const nameInput = contactSection.querySelector('input[name="name"]');
        const alignContactSection = () => {
          const top = window.scrollY + contactSection.getBoundingClientRect().top;
          window.scrollTo({ left: window.scrollX, top, behavior: 'instant' });
        };

        alignContactSection();
        requestAnimationFrame(() => {
          alignContactSection();
          if (nameInput instanceof HTMLInputElement) {
            nameInput.focus({ preventScroll: true });
          }
        });
      });
    };

    bindContactJump();
    document.addEventListener('astro:page-load', bindContactJump);
  })();
</script>

<script>
  import './ax-v2/ax-v2-client';
</script>
