---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const P = '/images/pages/';
const members = (await getCollection('colleagues')).map((e) => e.data).sort((a, b) => a.order - b.order);

const heading = {
  ko: { title: '코르카 사람들', sub: '능력있고 열정적인 코르카 팀 멤버들의 경험과 성장에 대한 생생한 이야기들을 만나보세요', newWindow: '(corca.team에서 열림)' },
  en: { title: 'Our People', sub: 'Discover the vivid stories of experience and growth from the talented, passionate members of the Corca team.', newWindow: '(opens on corca.team)' },
  ja: { title: 'コルカの人々', sub: '有能で情熱的なコルカのチームメンバーたちの経験と成長に関する、生き生きとしたストーリーをご覧ください。', newWindow: '(corca.team で開く)' },
  zh: { title: 'Corca 的伙伴们', sub: '欢迎了解Corca团队中才华横溢、充满热情的成员们关于经验与成长的生动故事。', newWindow: '(在 corca.team 打开)' },
}[lang];
---

<!-- Header band — pale-blue gradient behind the title, like corca.ai. -->
<section class="bg-gradient-to-b from-[#e1eaf7] to-white">
  <div class="container-c pb-8 pt-10 text-center lg:pt-24">
    <h1 class="font-body text-[21px] font-normal leading-[1.2] text-[#1a2352] md:text-[32px] lg:text-[44px] xl:text-[51px]">{heading.title}</h1>
    <p class="mx-auto mt-4 max-w-[620px] text-[15px] leading-[1.4] text-[#1a2352] md:text-[18px] lg:max-w-[820px]">{heading.sub}</p>
  </div>
</section>

<section class="bg-white">
  <div class="container-c pb-16 pt-8 lg:pb-24 lg:pt-10">
    <ul role="list" class="grid list-none gap-x-3 gap-y-10 p-0 grid-cols-2 md:grid-cols-3 md:gap-x-10 md:gap-y-12 lg:gap-x-[60px] lg:gap-y-16">
      {members.map((m) => (
        <li>
          <a href={m.story} target="_blank" rel="noopener" class="group flex flex-col">
            <div class="overflow-hidden rounded-2xl bg-black/5">
              <img src={`${P}${m.image}.webp`} alt="" loading="lazy" decoding="async" class="aspect-square w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]" />
            </div>
            <h2 class="font-body mt-5 text-[18px] font-normal leading-snug text-[#1a2352] lg:text-[20px]">{m.role[lang]}</h2>
            <p class="mt-3 text-[14px] leading-[1.4] text-[#1a2352] md:text-[15px]">{m.quote[lang]}</p>
            <span class="sr-only">{heading.newWindow}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
