---
import type { Lang } from '../../i18n/ui';
import { members, storyUrls } from '../../i18n/content/colleagues';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const P = '/images/pages/';

const heading = {
  ko: { title: '코르카 사람들', sub: '능력있고 열정적인 코르카 팀 멤버들의 경험과 성장에 대한 생생한 이야기들을 만나보세요', newWindow: '(corca.team에서 열림)' },
  en: { title: 'Our People', sub: 'Discover the vivid stories of experience and growth from the talented, passionate members of the Corca team.', newWindow: '(opens on corca.team)' },
  ja: { title: 'コルカの人々', sub: '有能で情熱的なコルカのチームメンバーたちの経験と成長に関する、生き生きとしたストーリーをご覧ください。', newWindow: '(corca.team で開く)' },
  zh: { title: 'Corca 的伙伴们', sub: '欢迎了解Corca团队中才华横溢、充满热情的成员们关于经验与成长的生动故事。', newWindow: '(在 corca.team 打开)' },
}[lang];
---

<!-- Header band — pale-blue gradient behind the title, like corca.ai. -->
<section class="bg-gradient-to-b from-[#e1eaf7] to-white">
  <div class="container-c pb-4 pt-16 text-center lg:pt-20">
    <h1 class="text-[38px] font-semibold text-[#1a2352] lg:text-[51px]">{heading.title}</h1>
    <p class="mx-auto mt-4 max-w-[680px] text-[15px] leading-relaxed text-[#1a2352] lg:text-[18px]">{heading.sub}</p>
  </div>
</section>

<section class="bg-white">
  <div class="container-c pb-16 pt-8 lg:pb-24 lg:pt-10">
    <ul role="list" class="grid list-none gap-x-8 gap-y-14 p-0 grid-cols-2 md:grid-cols-3">
      {members.map((m) => (
        <li>
          <a href={storyUrls[m.img]} target="_blank" rel="noopener" class="group flex flex-col">
            <div class="overflow-hidden rounded-xl bg-black/5">
              <img src={`${P}${m.img}.webp`} alt="" loading="lazy" decoding="async" class="aspect-square w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]" />
            </div>
            <h2 class="mt-4 text-[17px] font-semibold leading-snug text-ink transition-colors group-hover:text-brand lg:text-[18px]">{m.t[lang]}</h2>
            <p class="mt-2 line-clamp-3 text-[14px] leading-relaxed text-ink-soft">{m.q[lang]}</p>
            <span class="sr-only">{heading.newWindow}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
