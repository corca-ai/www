---
import { Image } from 'astro:assets';
import { useTranslations } from '../../i18n/utils';
import { externalLinks, type Lang } from '../../i18n/ui';
import { br } from '../../text';

import heroIllustration from '../../assets/images/hero-illustration.png';
import ProductShowcase from '../ProductShowcase.astro';
import awardUnicorn from '../../assets/images/award-unicorn.png';
import awardStartup from '../../assets/images/award-startup.png';
import recsysArticle from '../../assets/images/recsys-article.png';
import partners from '../../assets/images/partners.png';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const h = t.home;

// Localized alt text for the content images (issue #14: alt must be descriptive
// and in the page's language, not hardcoded English).
const imgAlt = {
  ko: {
    recsys: 'ACM RecSys Challenge 2023 성과를 다룬 코르카 관련 기사',
    partners: '코르카의 파트너사와 고객사 로고',
  },
  en: {
    recsys: 'Corca featured in an ACM RecSys Challenge 2023 news article',
    partners: 'Logos of Corca partners and clients',
  },
  ja: {
    recsys: 'ACM RecSys Challenge 2023の成果を報じたコルカ関連記事',
    partners: 'コルカのパートナー企業と顧客企業のロゴ',
  },
  zh: {
    recsys: '报道Corca在ACM RecSys Challenge 2023成绩的新闻文章',
    partners: 'Corca的合作伙伴与客户的标志',
  },
}[lang];
// Hero title: keep the authored \n break, and on small screens (<810px) add a
// second break before the last word of the second line so the hero wraps to
// three lines like corca.ai's mobile/tablet layout. Space-less scripts (ja/zh)
// have no last-word space, so they are unaffected. "AI" is given extra weight
// to mirror the live hero.
const heroTitleHtml = (() => {
  const [line1, line2 = ''] = h.heroTitle.split('\n');
  const sp = line2.lastIndexOf(' ');
  const line2Html =
    sp > 0 ? `${line2.slice(0, sp)} <br class="min-[810px]:hidden" />${line2.slice(sp + 1)}` : line2;
  return `${line1}<br />${line2Html}`;
})();
---

<!-- ============================ Hero ============================ -->
<section class="relative overflow-hidden bg-brand text-white">
  <!-- Hero geometry matches live: the illustration is min(60vw,768px) wide, flush
       to the right of a centred 1280 container (right = max(0,50vw−640)), and
       flush to the hero bottom. Live's header is a FIXED transparent overlay so
       its blue starts at y0 and runs `clamp(720,75vw,960)`; ours is a 66px opaque
       sticky bar, so we subtract that 66px here to land the illustration bottom at
       the same on-page position as live. -->
  <div class="container-c relative flex flex-col items-start gap-8 pt-6 pb-14 text-left min-[640px]:pb-6 min-[810px]:min-h-[clamp(654px,calc(75vw_-_66px),894px)] min-[810px]:justify-start min-[810px]:py-0 min-[810px]:pt-[calc(9vw_-_40px)]">
    <div class="max-[809px]:max-w-[360px] min-[810px]:max-w-[600px]">
      <h1
        class="text-[40px] font-normal leading-[1.12] tracking-tight min-[640px]:text-[42px] min-[810px]:text-[44px] min-[1024px]:text-[60px]"
        set:html={heroTitleHtml}
      />
      <p class="font-head mt-6 text-[18px] leading-[1.4] text-white min-[1024px]:text-[24px]" set:html={br(h.heroSubtitle)} />
    </div>
    <Image
      src={heroIllustration}
      alt=""
      widths={[440, 820, 1640]}
      sizes="(min-width: 810px) 56vw, 100vw"
      loading="eager"
      class="pointer-events-none w-[120%] max-w-[480px] select-none self-end -mt-[52px] -me-[max(20px,9.8vw_-_15px)] min-[640px]:-mt-[90px] min-[810px]:absolute min-[810px]:bottom-[0px] min-[810px]:right-[max(0px,calc(50vw_-_640px))] min-[810px]:mt-0 min-[810px]:me-0 min-[810px]:w-[60vw] min-[810px]:max-w-[768px]"
    />
  </div>
</section>

<!-- ==================== Moonlight / Trace ======================== -->
<ProductShowcase lang={lang} />

<!-- ===================== Baby Unicorn award ===================== -->
<section class="bg-white">
  <div class="container-c grid items-center gap-10 py-16 md:grid-cols-2 md:gap-16 lg:py-28">
    <div class="order-first">
      <div class="mx-auto flex max-w-[500px] flex-col items-center gap-6 rounded-2xl border border-black/10 px-8 py-10 text-center">
        <p class="text-[20px] font-normal leading-[1.2] text-brand-ink lg:text-[30px]">{h.babyUnicornBadge}</p>
        <Image src={awardUnicorn} alt="" width={420} height={135} densities={[1, 2]} class="w-full max-w-[420px]" />
        <Image src={awardStartup} alt="" width={300} height={60} densities={[1, 2]} class="w-[64%] max-w-[300px]" />
      </div>
    </div>
    <div>
      <h2 class="text-[26px] font-normal leading-[1.2] text-heading md:text-[28px] lg:text-[32px]" set:html={br(h.babyUnicornHeading)} />
      <a href={externalLinks.babyUnicornArticle} target="_blank" rel="noopener" class="btn-pill btn-pill-dark mt-7">{h.readArticle}</a>
    </div>
  </div>
</section>

<!-- ============================ RecSys ============================ -->
<section class="bg-white">
  <div class="container-c grid items-center gap-10 py-16 md:grid-cols-2 md:gap-16 lg:py-28">
    <div>
      <h2 class="text-[26px] font-normal leading-[1.2] text-heading md:text-[28px] lg:text-[32px]" set:html={br(h.recsysHeading)} />
      <a href={externalLinks.recsysArticle} target="_blank" rel="noopener" class="btn-pill btn-pill-dark mt-7">{h.readArticle}</a>
    </div>
    <div class="order-first md:order-last">
      <div class="rounded-2xl bg-[#e7eaf4] px-6 py-8 sm:px-10">
        <div class="text-center">
          <p class="font-head text-[14px] leading-[1.3] text-[#000] lg:text-[16px]">{h.recsysCaptionTop}</p>
          <p class="font-head text-[14px] leading-[1.3] text-[#000] lg:text-[16px]">{h.recsysEvent}</p>
          <p class="mt-2 text-[20px] font-normal leading-[1.2] text-brand-ink md:text-[24px] lg:text-[28px]">{h.recsysRank}</p>
        </div>
        <Image
          src={recsysArticle}
          alt={imgAlt.recsys}
          widths={[560, 900]}
          sizes="(min-width: 1024px) 45vw, 90vw"
          class="mt-6 w-full rounded-xl shadow-[var(--shadow-card)]"
        />
      </div>
    </div>
  </div>
</section>

<!-- =========================== Partners =========================== -->
<section class="bg-white">
  <div class="container-c grid items-center gap-10 py-16 md:grid-cols-2 md:gap-16 lg:py-28">
    <div class="order-first">
      <Image
        src={partners}
        alt={imgAlt.partners}
        widths={[560, 1000]}
        sizes="(min-width: 768px) 50vw, 92vw"
        class="w-full"
      />
    </div>
    <div>
      <h2 class="font-body text-[26px] font-normal leading-[1.2] text-heading md:text-[28px] lg:text-[36px]" set:html={br(h.partnersHeading)} />
    </div>
  </div>
</section>

<!-- ========================= Closing CTA ========================= -->
<section class="bg-brand text-white">
  <div class="container-c flex flex-col items-center gap-5 py-40 text-center md:py-36 lg:py-44">
    <h2 class="font-body text-[22px] font-normal leading-[1.2] md:text-[38px]">{h.closingHeading}</h2>
    <p class="max-w-2xl text-[15px] leading-[1.4] text-white md:text-[16px]">{h.closingSubtitle}</p>
  </div>
</section>
