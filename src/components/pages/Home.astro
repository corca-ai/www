---
import { Image } from 'astro:assets';
import { useTranslations, localizePath } from '../../i18n/utils';
import { externalLinks, type Lang } from '../../i18n/ui';

import heroIllustration from '../../assets/images/hero-illustration.png';
import moonlightLogo from '../../assets/images/moonlight-logo.png';
import moonlightApp from '../../assets/images/moonlight-app.jpg';
import traceLogo from '../../assets/images/trace-logo.png';
import traceApp from '../../assets/images/trace-app.jpg';
import awardUnicorn from '../../assets/images/award-unicorn.png';
import awardStartup from '../../assets/images/award-startup.png';
import recsysArticle from '../../assets/images/recsys-article.png';
import partners from '../../assets/images/partners.png';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const h = t.home;
const br = (s: string) => s.replace(/\n/g, '<br />');
// Hero title: keep the authored \n break, and on small screens (<810px) add a
// second break before the last word of the second line so the hero wraps to
// three lines like corca.ai's mobile/tablet layout. Space-less scripts (ja/zh)
// have no last-word space, so they are unaffected. "AI" is given extra weight
// to mirror the live hero.
const heroTitleHtml = (() => {
  const [line1, line2 = ''] = h.heroTitle.split('\n');
  const sp = line2.lastIndexOf(' ');
  const line2Html =
    sp > 0 ? `${line2.slice(0, sp)} <br class="min-[810px]:hidden" />${line2.slice(sp + 1)}` : line2;
  return `${line1}<br />${line2Html}`;
})();
---

<!-- ============================ Hero ============================ -->
<section class="relative overflow-hidden bg-brand text-white">
  <div class="container-c relative flex flex-col items-start gap-8 pt-6 pb-14 text-left min-[640px]:pb-6 min-[810px]:min-h-[calc(480px_+_33vw)] min-[810px]:justify-start min-[810px]:py-0 min-[810px]:pt-[calc(9vw_-_40px)]">
    <div class="max-[809px]:max-w-[360px] min-[810px]:max-w-[600px]" data-reveal>
      <h1
        class="text-[33px] font-normal leading-[1.12] tracking-tight min-[640px]:text-[42px] min-[810px]:text-[44px] min-[1024px]:text-[60px]"
        set:html={heroTitleHtml}
      />
      <p class="font-head mt-6 text-[18px] leading-[1.4] text-white min-[1024px]:text-[24px]" set:html={br(h.heroSubtitle)} />
    </div>
    <Image
      src={heroIllustration}
      alt=""
      widths={[440, 820, 1640]}
      sizes="(min-width: 810px) 56vw, 100vw"
      loading="eager"
      class="pointer-events-none w-[120%] max-w-[480px] select-none self-end -mt-[52px] -me-[max(20px,9.8vw_-_15px)] min-[640px]:-mt-[90px] min-[810px]:absolute min-[810px]:bottom-[45px] min-[810px]:right-[80px] min-[810px]:mt-0 min-[810px]:me-0 min-[810px]:w-[54%] min-[810px]:max-w-[770px]"
    />
  </div>
</section>

<!-- ========================== Moonlight ========================== -->
<section class="bg-white">
  <div class="container-c grid items-center gap-10 py-16 md:grid-cols-2 md:gap-16 lg:py-28">
    <div class="order-first" data-reveal>
      <Image
        src={moonlightApp}
        alt="Moonlight app screenshot"
        widths={[560, 900]}
        sizes="(min-width: 768px) 50vw, 92vw"
        class="w-full rounded-2xl shadow-[var(--shadow-card)]"
      />
    </div>
    <div data-reveal style="--reveal-delay: .12s">
      <Image src={moonlightLogo} alt="Moonlight" width={200} height={55} densities={[1, 2, 3]} class="h-[52px] w-auto md:h-[72px]" />
      <h2 class="mt-5 text-[26px] font-normal leading-[1.2] text-heading md:text-[28px] lg:text-[32px]">{h.moonlightHeading}</h2>
      <p class="mt-5 text-[16px] leading-[1.4] text-heading lg:text-[18px]">{h.moonlightBody}</p>
      <a href={localizePath('/moonlight', lang)} class="btn-pill btn-pill-lg mt-8 w-full justify-center border-transparent bg-[#605070] text-white hover:bg-[#4d4159] md:w-auto">{h.readMore}</a>
    </div>
  </div>
</section>

<!-- ============================ Trace ============================ -->
<section class="bg-lavender">
  <div class="container-c grid items-center gap-10 py-16 md:grid-cols-2 md:gap-16 lg:py-28">
    <div class="order-first md:order-last" data-reveal>
      <Image
        src={traceApp}
        alt="Trace app screenshot"
        widths={[560, 900]}
        sizes="(min-width: 768px) 50vw, 92vw"
        class="w-full rounded-2xl shadow-[var(--shadow-card)]"
      />
    </div>
    <div data-reveal style="--reveal-delay: .12s">
      <Image src={traceLogo} alt="Trace" width={190} height={57} densities={[1, 2, 3]} class="h-[52px] w-auto md:h-[72px]" />
      <h2 class="mt-5 text-[26px] font-normal leading-[1.2] text-heading md:text-[28px] lg:text-[32px]">{h.traceHeading}</h2>
      <p class="mt-5 text-[16px] leading-[1.4] text-heading lg:text-[18px]">{h.traceBody}</p>
      <a href={localizePath('/trace', lang)} class="btn-pill btn-pill-lg mt-8 w-full justify-center border-transparent bg-[#777cdc] text-white hover:bg-[#6469c9] md:w-auto">{h.readMore}</a>
    </div>
  </div>
</section>

<!-- ===================== Baby Unicorn award ===================== -->
<section class="bg-white">
  <div class="container-c grid items-center gap-10 py-16 md:grid-cols-2 md:gap-16 lg:py-28">
    <div class="order-first" data-reveal>
      <div class="mx-auto flex max-w-[500px] flex-col items-center gap-6 rounded-2xl border border-black/10 px-8 py-10 text-center">
        <p class="text-[20px] font-normal leading-[1.2] text-brand-ink lg:text-[30px]">{h.babyUnicornBadge}</p>
        <Image src={awardUnicorn} alt="" width={420} height={135} densities={[1, 2]} class="w-full max-w-[420px]" />
        <Image src={awardStartup} alt="" width={300} height={60} densities={[1, 2]} class="w-[64%] max-w-[300px]" />
      </div>
    </div>
    <div data-reveal style="--reveal-delay: .12s">
      <h2 class="text-[26px] font-normal leading-[1.2] text-heading md:text-[28px] lg:text-[32px]" set:html={br(h.babyUnicornHeading)} />
      <a href={externalLinks.babyUnicornArticle} target="_blank" rel="noopener" class="btn-pill btn-pill-dark mt-7">{h.readArticle}</a>
    </div>
  </div>
</section>

<!-- ============================ RecSys ============================ -->
<section class="bg-white">
  <div class="container-c grid items-center gap-10 py-16 md:grid-cols-2 md:gap-16 lg:py-28">
    <div data-reveal>
      <h2 class="text-[26px] font-normal leading-[1.2] text-heading md:text-[28px] lg:text-[32px]" set:html={br(h.recsysHeading)} />
      <a href={externalLinks.recsysArticle} target="_blank" rel="noopener" class="btn-pill btn-pill-dark mt-7">{h.readArticle}</a>
    </div>
    <div class="order-first md:order-last" data-reveal style="--reveal-delay: .12s">
      <div class="rounded-2xl bg-[#e7eaf4] px-6 py-8 sm:px-10">
        <div class="text-center">
          <p class="text-[16px] leading-[1.3] text-[#111]">{h.recsysCaptionTop}</p>
          <p class="text-[16px] leading-[1.3] text-[#111]">{h.recsysEvent}</p>
          <p class="mt-2 text-[20px] font-normal leading-[1.2] text-brand-ink md:text-[24px] lg:text-[28px]">{h.recsysRank}</p>
        </div>
        <Image
          src={recsysArticle}
          alt="Corca featured in ACM RecSys Challenge 2023 news article"
          widths={[560, 900]}
          sizes="(min-width: 1024px) 45vw, 90vw"
          class="mt-6 w-full rounded-xl shadow-[var(--shadow-card)]"
        />
      </div>
    </div>
  </div>
</section>

<!-- =========================== Partners =========================== -->
<section class="bg-white">
  <div class="container-c grid items-center gap-10 py-16 md:grid-cols-2 md:gap-16 lg:py-28">
    <div class="order-first" data-reveal>
      <Image
        src={partners}
        alt="Corca partners and clients"
        widths={[560, 1000]}
        sizes="(min-width: 768px) 50vw, 92vw"
        class="w-full"
      />
    </div>
    <div data-reveal style="--reveal-delay: .12s">
      <h2 class="text-[26px] font-normal leading-[1.2] text-heading md:text-[28px] lg:text-[32px]" set:html={br(h.partnersHeading)} />
    </div>
  </div>
</section>

<!-- ========================= Closing CTA ========================= -->
<section class="bg-brand text-white">
  <div class="container-c flex flex-col items-center gap-5 py-40 text-center md:py-36 lg:py-44" data-reveal>
    <h2 class="text-[26px] font-normal leading-[1.2] md:text-[38px]">{h.closingHeading}</h2>
    <p class="max-w-2xl text-[15px] leading-[1.4] text-white lg:text-[16px]">{h.closingSubtitle}</p>
  </div>
</section>
