const c = { ko, en, ja, zh }[lang];
const br = (s: string) => s.replace(/\n/g, '<br />');
---

<!-- Hero — full-bleed island illustration from the top with the title overlaid
     on its upper-left empty space, matching corca.ai. -->
<section class="relative overflow-hidden bg-white">
  <!-- Live zooms this landscape illustration on mobile/tablet (cropping the
       sides) so the scene fills a taller band; we mirror that with a >100%
       width centered inside the section's overflow-hidden crop. -->
  <div class="flex justify-center">
    <img src={HERO} alt="" width="1440" height="1100" decoding="async" class="block h-auto w-[195%] max-w-none shrink-0 md:w-[180%] lg:w-full" />
  </div>
  <div class="container-c absolute inset-x-0 top-0 z-10 pt-6 sm:pt-10 lg:pt-20">
    <h1 class="text-[39px] font-normal leading-tight text-[#1a2352] sm:text-[44px] lg:text-[74px]" set:html={br(c.heroTitle)} />
    <p class="mt-3 max-w-[300px] text-[13px] leading-relaxed text-[#1a2352] sm:mt-5 sm:max-w-[390px] sm:text-[16px] lg:max-w-[560px] lg:text-[20px]">{c.heroSubtitle}</p>
  </div>
</section>

<!-- Methods — deep sea-blue that seamlessly continues the hero illustration's
     water (live corca.ai uses #046eb8 here, not the brighter hero blue). -->
<!-- Deep sea-blue that seamlessly continues the (now bottom-cropped) hero sea, so
     the "일하는 방식" heading tucks under the boat like live. Small top padding
     keeps it close to the illustration at every breakpoint. -->
<section class="bg-[#046eb8] text-white">
  <div class="container-c pb-16 pt-6 lg:pb-20 lg:pt-8">
    <h2 class="text-[31px] font-normal lg:text-[50px]">{c.methodsLabel}</h2>
    <div class="mt-10 flex flex-col gap-14 lg:gap-20">
      {c.methods.map((m, i) => (
        <div class:list={["grid items-center gap-8 md:grid-cols-2 md:gap-12", i % 2 === 1 && "md:[&>*:first-child]:order-last"]}>
          <div class:list={[i % 2 === 1 && 'md:order-last']}>
            <h3 class="text-[22px] font-normal md:text-[28px] lg:text-[36px]">{m.title}</h3>
            <p class="mt-4 text-[15px] leading-relaxed text-white lg:text-[16px]">{m.body}</p>
          </div>
          <div class:list={["flex justify-center", i % 2 === 1 && 'md:order-first']}>
            <img src={m.img} alt="" width="320" height="240" loading="lazy" decoding="async" class="h-auto w-[260px] max-w-full lg:w-[320px]" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Office photos — live stacks full-width landscape photos on mobile, switching
     to a square multi-column grid from sm up. -->
<section class="bg-white">
  <div class="grid grid-cols-1 md:grid-cols-5">
    {PHOTOS.map((src) => (
      <img src={src} alt="" class="aspect-[16/9] w-full object-cover md:aspect-square" loading="lazy" decoding="async" />
    ))}
  </div>
</section>

<!-- Benefits -->
<section class="bg-white">
  <div class="container-c grid gap-10 py-16 md:grid-cols-[220px_1fr] md:gap-12 lg:grid-cols-[260px_1fr] lg:gap-16 lg:py-24">
    <h2 class="text-[31px] font-normal text-[#1a2352] lg:text-[50px]">{c.envLabel}</h2>
    <div class="flex flex-col gap-10">
      {c.benefits.map((b) => (
        <div class="flex gap-5">
          <span class="shrink-0 text-[32px] leading-none lg:text-[38px]" aria-hidden="true">{b.icon}</span>
          <div>
            <h3 class="text-[18px] font-normal text-[#1a2352] lg:text-[21px]">{b.title}</h3>
            <p class="mt-2 text-[15px] leading-relaxed text-[#1a2352] lg:text-[16px]">{b.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
