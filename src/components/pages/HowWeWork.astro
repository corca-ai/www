---
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const P = '/images/pages/';
// Cropped to remove the illustration's trailing "sea" band below the boat (the
// original 1440x1217 master has ~117px of flat #046eb8 sea at the bottom); live
// corca.ai crops it so the methods heading tucks under the boat. The crop line
// is flat sea == the methods section bg, so the seam is invisible at every zoom.
const HERO = `${P}how-we-work-hero.webp`;
const ISO_STRUCTURE = `${P}2fe9a6_27eadb8d7d914426b56ccaf2c96ac22d.webp`;
const ISO_LADDER = `${P}2fe9a6_9931d659ab8d44e488da606935878568.webp`;
const ISO_STUDY = `${P}2fe9a6_20e646ee0e3a4dddb332665db0023f2e.webp`;
const PHOTOS = [
  `${P}2fe9a6_6137577504cd418dbbb43f8238b9aaa1.webp`,
  `${P}2fe9a6_aeedb44afb144ddf97c4c6350706e563.webp`,
  `${P}2fe9a6_7b41924b3738498ab454d78ee7f4c9f6.webp`,
  `${P}2fe9a6_537cd02fc1aa4fa3bb2ad28ea7eaf8bc.webp`,
  `${P}2fe9a6_f9cd4f032afc4e9f98dbfc6b88d480b6.webp`,
];

// Fully localized in all four languages. (The original Wix site fell back to
// Korean on /ja/how-we-work; our version provides a proper Japanese translation.)
const ko = {
  heroTitle: '코르카는,\n이렇게 일해요',
  heroSubtitle: '코르카는 멤버의 성장과 복지를 위해 최적의 근무 환경을 제공하고 역량 개발에 힘쓰고 있습니다.',
  methodsLabel: '일하는 방식',
  methods: [
    { title: '조직 구조', body: '코르카의 조직구조는 기능조직과 목적조직으로 나뉘어요. 각 챕터-스쿼드 별 Mission과 Strategy를 가지고 같은 목표를 바라보고 일해요. 건강한 피드백, 회고, 스크럼을 통해 팀과 프로덕트의 성장에 집중해요.', img: ISO_STRUCTURE },
    { title: '커리어 래더', body: '코르카 테크팀은 코르카 안에서 임팩트를 내는 방법에 대한 가이드인 코르카 래더가 있어요. 커리어 래더를 통해 본인의 현재 임팩트를 측정하고 매니저와 논의하여 다음 스텝으로 나아가기 위한 구체적인 계획을 세워보세요.', img: ISO_LADDER },
    { title: '다양한 커리큘럼과 스터디', body: '코르카는 신규 입사자들이 업무에 보다 빠르게 적응할 수 있는 커리큘럼과 팀원들이 자율적으로 운영하는 스터디를 적극적으로 지원하고 있어요. 지금까지 했던 스터디는 MLOps Curriculum, Data Curriculum, Lead Engineer Maker, CUDA, 강화학습, 리팩토링 등이 있고 계속 추가되고 있습니다!', img: ISO_STUDY },
  ],
  envLabel: '일하는 환경',
  benefits: [
    { icon: '💰', title: '직무 교육비 지원', body: '코르카는 팀원의 성장이 곧 팀 전체의 성장이라고 믿어요. 성과와 성장에 도움이 된다면 어떤 교육이든 아낌없이 지원해요. 외부 컨퍼런스 참석, 직무 관련 교육뿐 아니라 업무 생산성을 높이는 AI 도구 구독료도 지원하고 있어요.' },
    { icon: '📚', title: '도서 지원', body: '회사와 팀원의 성장을 위해 필요한 도서 구매를 지원해요. 코르카 Library에서 도서 목록과 팀원들이 남긴 감상평을 확인할 수 있어요.' },
    { icon: '🤝', title: '버디 프로그램', body: '코르카에 새로 합류한 신규 입사자들의 적응을 돕기 위해 버디프로그램을 진행하고 있어요. 출근 첫 날, 걱정하지 마세요! 편하게 이야기 나눌 수 있도록 버디챗 비용도 지원해요!' },
    { icon: '🎤', title: '성장을 위한 세미나 진행', body: '다양한 세미나를 진행하며 팀원들의 지속가능한 성장과 퍼포먼스를 지원하고 있어요. 내부 세미나 외에도 외부 초청 세미나도 진행하여 많은 인사이트를 얻을 수 있어요.' },
    { icon: '👥', title: '수평적인 조직, 든든한 팀워크', body: '~님 호칭을 통일하고 있어요. 건강하고 자유로운 토론을 통해 프로젝트의 진행 방향을 결정하고 있어요. 배울 점이 많은, 긍정적인 자극이 되는 동료들과 함께 일할 수 있어요!' },
    { icon: '🕐', title: '유연한 출퇴근 시간', body: '선택적 근로시간제로 근무 시간을 유연하게 조정할 수 있어요. Co-work Time (오전 10시 30분 - 오후 4시) 운영으로 팀원 간 원활한 소통이 가능해요.' },
    { icon: '🧰', title: '기술 스택 적극 도입', body: '프로젝트 진행에 필요한 업무 도구 활용을 적극적으로 권장하며 지원하고 있어요.' },
    { icon: '💻', title: '최상의 장비 지원', body: 'MacBook Pro/Air, LG 그램 중 선택하여 사용할 수 있어요. 모니터, 기계식 키보드 등 업무에 필요한 모든 장비를 적극 지원하고 있어요!' },
    { icon: '🍱', title: '넉넉한 식대와 간식', body: '한국인은 밥심! 맛있게 먹고 기분 좋게 일할 수 있도록 넉넉한 점심 식대와 야간 근무 시 동일한 저녁 식대를 제공해요. 간식도 든든히 제공하고 있어요.' },
    { icon: '🎂', title: '생일 휴가', body: '코르카 멤버가 태어난 날을 축하하는 마음을 가득 담아 생일 휴가 하루를 지급해요. 매달 생일파티를 열어 다같이 축하해주는 시간도 갖고 있어요!' },
    { icon: '🎗️', title: '경조사 지원', body: '기쁠 때나 슬플 때나 코르카가 함께 해요. 규정에 따른 경조휴가, 경조비를 지급하고 있어요.' },
  ],
};

