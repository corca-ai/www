---
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const HERO_BG = '/images/pages/2fe9a6_c547632b877545b1ac6444eddee05fd8.webp';
// White-wordmark version (icon kept, "Moonlight" text recolored white) so the
// logo reads on the dark hero — the original asset has dark-purple text baked in.
const LOGO = '/images/pages/moonlight-logo-white.webp';
const APP_URL = 'https://themoonlight.io/';

const content = {
  ko: {
    title: '연구자들을 위한 AI PDF 논문 리더',
    body: '문라이트는 AI를 이용하여 어려운 논문을 빠르고 쉽게 이해하고 요약할 수 있으며 이 외에도 스마트 인용, 페이지 번역, 오토 하이라이트, 서지 관리, 논문 검색, 아이디에이션 등 연구에 도움을 주는 다양한 기능을 제공합니다.',
    cta: '지금 사용해 보기',
    stats: [
      { label: '사용자', value: '100,000+' },
      { label: '읽은 논문', value: '1.7M+' },
      { label: '사용 국가', value: '150+' },
      { label: '사용 기관', value: '1,000+' },
    ],
  },
  en: {
    title: 'AI PDF Paper Reader for Researchers',
    body: 'Moonlight uses AI to help you quickly and easily understand and summarize difficult papers, and offers a range of features that support your research — smart citation, page translation, auto-highlighting, bibliography management, paper search, and ideation.',
    cta: 'Try it now',
    stats: [
      { label: 'Users', value: '100,000+' },
      { label: 'Papers read', value: '1.7M+' },
      { label: 'Countries', value: '150+' },
      { label: 'Institutions', value: '1,000+' },
    ],
  },
  ja: {
    title: '研究者のためのAI論文リーダー',
    body: 'ムーンライトは、AIの力で難解な論文をスピーディーかつわかりやすく理解・要約できます。さらに、スマート引用、ページ翻訳、自動ハイライト、文献管理、論文検索、アイデア発想支援など、研究に役立つ多彩な機能を備えています。',
    cta: '今すぐ試す',
    stats: [
      { label: 'ユーザー数', value: '100,000+' },
      { label: '読了論文数', value: '1.7M+' },
      { label: '利用国数', value: '150+' },
      { label: '利用機関数', value: '1,000+' },
    ],
  },
  zh: {
    title: '为研究者打造的AI PDF论文阅读器',
    body: 'Moonlight利用AI帮助您快速、轻松地理解和总结艰深的论文，还提供智能引用、页面翻译、自动高亮、文献管理、论文检索、创意发想等多种助力研究的功能。',
    cta: '立即试用',
    stats: [
      { label: '用户', value: '100,000+' },
      { label: '已读论文', value: '1.7M+' },
      { label: '使用国家', value: '150+' },
      { label: '使用机构', value: '1,000+' },
    ],
  },
};
const c = content[lang];
// The h1 uses the Corca heading font, whose Latin ("AI PDF") is already a bold
// serif — no manual markup needed.
const titleHtml = c.title;

// Stat icons (users / papers read / countries / institutions), mirroring the
// original site's pictograms. Decorative — text labels carry the meaning.
const statIcons = [
  'M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm-7 9a7 7 0 0 1 14 0M17 3.5a4 4 0 0 1 0 7.4M22 20a7 7 0 0 0-4.6-6.6',
  'M12 5.5C10.5 4 8.4 3 5.5 3 4 3 2.9 3.3 2 3.7V19c.9-.4 2-.7 3.5-.7 2.9 0 5 1 6.5 2.5 1.5-1.5 3.6-2.5 6.5-2.5 1.5 0 2.6.3 3.5.7V3.7C21.1 3.3 20 3 18.5 3 15.6 3 13.5 4 12 5.5Zm0 0V21',
  'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm0 0c2.5-2.2 4-5.4 4-9s-1.5-6.8-4-9c-2.5 2.2-4 5.4-4 9s1.5 6.8 4 9Zm-8.5-9h17',
  'M3 21h18M5 21V7l7-4 7 4v14M9 21v-4h6v4M9 9h.01M12 9h.01M15 9h.01M9 13h.01M12 13h.01M15 13h.01',
];
---

<!-- Hero — a purple app-screenshot montage under a strong purple filter (~0.66
     opacity, calibrated to live corca.ai) so the bright screenshots are dimmed to
     a readable dark-purple and the white title/body stay legible. Too light an
     overlay (the old 0.18–0.34) let the montage show through and the text vanished. -->
<section
  class="relative bg-[#402060] bg-cover bg-center"
  style={`background-image: linear-gradient(rgba(58,25,90,0.64), rgba(46,18,74,0.72)), url('${HERO_BG}');`}
>
  <div class="container-c flex min-h-[500px] flex-col items-center justify-center gap-6 py-16 text-center text-white md:min-h-[720px] lg:min-h-[960px] lg:gap-7 lg:py-24">
    <img src={LOGO} alt="Moonlight" width="460" height="131" class="w-[245px] max-w-full sm:w-[330px] lg:w-[500px]" data-reveal />
    <h1 class="text-[34px] font-normal leading-[1.2] sm:text-[40px] lg:text-[60px]" data-reveal style="--reveal-delay: .1s" set:html={titleHtml} />
    <p class="max-w-[840px] text-[14px] leading-[1.5] text-white md:text-[18px] lg:text-[20px]" data-reveal style="--reveal-delay: .2s">{c.body}</p>
    <a
      href={APP_URL}
      target="_blank"
      rel="noopener"
      class="btn-pill btn-pill-lg mt-2 border-transparent bg-white text-[#402060] hover:bg-white/90"
      data-reveal
      style="--reveal-delay: .3s"
    >{c.cta}</a>
  </div>
</section>

<!-- Stats — folds open on scroll, like the original page's entry animation. -->
<section class="bg-[#1a2352] text-white">
  <div class="container-c grid grid-cols-2 gap-y-6 py-10 text-center md:grid-cols-4 md:gap-y-8 lg:py-14" data-reveal="fold">
    {c.stats.map((s, i) => (
      <div class="flex flex-col items-center gap-1">
        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="text-white/80">
          <path d={statIcons[i]} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        <p class="text-[14px] text-white/70 lg:text-[18px]">{s.label}</p>
        <p class="text-[30px] font-semibold lg:text-[46px]">{s.value}</p>
      </div>
    ))}
  </div>
</section>
