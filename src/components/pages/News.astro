---
import type { Lang } from '../../i18n/ui';
import { newsItems } from '../../i18n/content/news';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const P = '/images/pages/';
const items = newsItems;

const heading = {
  ko: { display: 'News', title: '뉴스기사로 보는 코르카의 성과', newWindow: '(새 창에서 열림)' },
  en: { display: 'News', title: 'News & Articles', newWindow: '(opens in a new window)' },
  ja: { display: 'News', title: 'ニュースで見るコルカの成果', newWindow: '(新しいウィンドウで開く)' },
  zh: { display: 'News', title: '新闻报道中的Corca成果', newWindow: '(在新窗口中打开)' },
}[lang];
---

<!-- Header band — pale-blue gradient behind the title, like corca.ai. -->
<section class="bg-gradient-to-b from-[#e1eaf7] to-white">
  <div class="container-c pb-4 pt-16 text-center lg:pt-20">
    <h1 class="text-[38px] font-semibold text-[#1a2352] lg:text-[51px]">{heading.display}</h1>
    <p class="mt-3 text-[15px] leading-relaxed text-[#1a2352] lg:text-[18px]">{heading.title}</p>
  </div>
</section>

<section class="bg-white">
  <div class="container-c pb-16 pt-8 lg:pb-24 lg:pt-10">
    <ul role="list" class="grid list-none gap-x-8 gap-y-14 p-0 grid-cols-2 md:grid-cols-3">
      {items.map((n) => (
        <li>
          <a href={n.h} target="_blank" rel="noopener" class="group block">
            <div class="overflow-hidden rounded-xl bg-black/5">
              <img
                src={`${P}${n.img}.webp`}
                alt=""
                loading="lazy"
                class="aspect-[4/3] w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
              />
            </div>
            <h2 class="mt-4 line-clamp-2 text-[16px] font-medium leading-snug text-ink transition-colors group-hover:text-brand">{n.t[lang]}</h2>
            <p class="mt-2 text-[13px] text-ink-soft">{n.d}</p>
            <span class="sr-only">{heading.newWindow}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
