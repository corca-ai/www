---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const P = '/images/pages/';
const asDate = (d: string) => new Date(d.replace(/\//g, '-')).getTime();
// Machine-readable date for <time datetime>: "2026/3/25" → "2026-03-25".
const isoDate = (d: string) => {
  const [y = '', m = '', day = ''] = d.split('/');
  return `${y}-${m.padStart(2, '0')}-${day.padStart(2, '0')}`;
};
const items = (await getCollection('news')).map((e) => e.data).sort((a, b) => asDate(b.date) - asDate(a.date));

const heading = {
  ko: { display: 'News', title: '뉴스기사로 보는 코르카의 성과', newWindow: '(새 창에서 열림)' },
  en: { display: 'News', title: 'News & Articles', newWindow: '(opens in a new window)' },
  ja: { display: 'News', title: 'ニュースで見るコルカの成果', newWindow: '(新しいウィンドウで開く)' },
  zh: { display: 'News', title: '新闻报道中的Corca成果', newWindow: '(在新窗口中打开)' },
}[lang];
---

<!-- Header band — pale-blue gradient behind the title, like corca.ai. -->
<section class="bg-gradient-to-b from-[#e1eaf7] to-white">
  <div class="container-c pb-9 pt-11 text-center md:pb-10 md:pt-16">
    <h1 class="font-body text-[26px] font-normal leading-[1.2] text-[#1a2352] md:text-[30px] lg:text-[44px] xl:text-[51px]">{heading.display}</h1>
    <p class="mt-3 text-[15px] leading-[1.4] text-[#1a2352] md:text-[18px]">{heading.title}</p>
  </div>
</section>

<section class="bg-white">
  <div class="container-c pb-16 pt-8 lg:pb-24 lg:pt-10">
    <ul role="list" class="grid list-none gap-x-3 gap-y-7 p-0 grid-cols-2 md:grid-cols-3 md:gap-x-10 md:gap-y-12 lg:gap-x-[60px] lg:gap-y-14">
      {items.map((n) => (
        <li>
          <a href={n.href} target="_blank" rel="noopener" class="group block">
            <div class="overflow-hidden rounded-xl bg-black/5">
              <img
                src={`${P}${n.image}.webp`}
                alt=""
                loading="lazy"
                class="aspect-[16/9] w-full object-cover"
              />
            </div>
            <h2 class="font-body mt-4 line-clamp-3 text-[16px] font-semibold leading-[1.25] text-heading [text-wrap:normal] md:text-[18px] lg:text-[20px]">{n.title[lang]}</h2>
            <p class="mt-4 text-[14px] text-[#8a8f99]"><time datetime={isoDate(n.date)}>{n.date}</time></p>
            <span class="sr-only">{heading.newWindow}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
