---
import type { Lang } from '../../i18n/ui';
import { newsItems } from '../../i18n/content/news';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const P = '/images/pages/';
const items = newsItems;

const heading = {
  ko: { display: 'News', title: '뉴스기사로 보는 코르카의 성과', newWindow: '(새 창에서 열림)' },
  en: { display: 'News', title: 'News & Articles', newWindow: '(opens in a new window)' },
  ja: { display: 'News', title: 'ニュースで見るコルカの成果', newWindow: '(新しいウィンドウで開く)' },
  zh: { display: 'News', title: '新闻报道中的Corca成果', newWindow: '(在新窗口中打开)' },
}[lang];
---

<!-- Header band — pale-blue gradient behind the title, like corca.ai. -->
<section class="bg-gradient-to-b from-[#e1eaf7] to-white">
  <div class="container-c pb-8 pt-10 text-center lg:pt-24">
    <h1 class="text-[26px] font-normal text-[#1a2352] md:text-[30px] lg:text-[51px]">{heading.display}</h1>
    <p class="mt-3 text-[15px] leading-relaxed text-[#1a2352] lg:text-[18px]">{heading.title}</p>
  </div>
</section>

<section class="bg-white">
  <div class="container-c pb-16 pt-8 lg:pb-24 lg:pt-10">
    <ul role="list" class="grid list-none gap-x-3 gap-y-7 p-0 grid-cols-2 md:grid-cols-3 md:gap-x-8 md:gap-y-12 lg:gap-x-[60px] lg:gap-y-14">
      {items.map((n) => (
        <li>
          <a href={n.h} target="_blank" rel="noopener" class="group block">
            <div class="overflow-hidden rounded-xl bg-black/5">
              <img
                src={`${P}${n.img}.webp`}
                alt=""
                loading="lazy"
                class="aspect-square w-full object-cover transition-transform duration-300 group-hover:scale-[1.03] md:aspect-[3/2] lg:aspect-[5/4]"
              />
            </div>
            <h2 class="mt-4 line-clamp-3 text-[16px] font-medium leading-snug text-heading transition-colors group-hover:text-brand [text-wrap:normal] md:text-[18px] lg:text-[20px]">{n.t[lang]}</h2>
            <p class="mt-4 text-[14px] text-[#8a8b99] md:text-[15px] lg:text-[17px]">{n.d}</p>
            <span class="sr-only">{heading.newWindow}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
