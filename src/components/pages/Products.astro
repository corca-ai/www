---
import type { Lang } from '../../i18n/ui';
import ProductShowcase from '../ProductShowcase.astro';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Category landing (issue #28). The product cards are generated from the product
// registry — the page's own copy (heading/CTA) is the only thing kept here.
const t = {
  ko: { title: '제품 소개', sub: '연구·업무·비즈니스 현장에 바로 쓰이는 코르카의 AI 제품을 만나보세요.', cta: '자세히 보기' },
  en: { title: 'Products', sub: 'Meet Corca’s AI products, ready to use in research, work, and business.', cta: 'Learn more' },
  ja: { title: '製品紹介', sub: '研究・業務・ビジネスの現場ですぐに使えるコルカのAI製品をご紹介します。', cta: '詳しく見る' },
  zh: { title: '产品介绍', sub: '一起了解可直接用于研究、工作与商业场景的Corca AI产品。', cta: '了解更多' },
}[lang];
---

<section class="bg-gradient-to-b from-[#e1eaf7] to-white">
  <div class="container-c pb-9 pt-11 text-center md:pb-10 md:pt-16">
    <h1 class="font-body text-[26px] font-normal leading-[1.2] text-[#1a2352] md:text-[32px] lg:text-[44px] xl:text-[51px]">{t.title}</h1>
    <p class="mx-auto mt-3 max-w-[720px] text-[15px] leading-[1.4] text-[#1a2352] md:text-[18px]">{t.sub}</p>
  </div>
</section>

<ProductShowcase lang={lang} compact />
