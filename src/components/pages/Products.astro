---
import { Image } from 'astro:assets';
import type { Lang } from '../../i18n/ui';
import { localizePath } from '../../i18n/utils';
import { products } from '../../products/registry';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// Category landing (issue #28). The product cards are generated from the product
// registry — the page's own copy (heading/CTA) is the only thing kept here.
const t = {
  ko: { title: '제품 소개', sub: '연구·업무·비즈니스 현장에 바로 쓰이는 코르카의 AI 제품을 만나보세요.', cta: '자세히 보기' },
  en: { title: 'Products', sub: 'Meet Corca’s AI products, ready to use in research, work, and business.', cta: 'Learn more' },
  ja: { title: '製品紹介', sub: '研究・業務・ビジネスの現場ですぐに使えるコルカのAI製品をご紹介します。', cta: '詳しく見る' },
  zh: { title: '产品介绍', sub: '一起了解可直接用于研究、工作与商业场景的Corca AI产品。', cta: '了解更多' },
}[lang];
---

<section class="bg-gradient-to-b from-[#e1eaf7] to-white">
  <div class="container-c pb-8 pt-10 text-center lg:pt-24">
    <h1 class="font-body text-[26px] font-normal leading-[1.2] text-[#1a2352] md:text-[32px] lg:text-[44px] xl:text-[51px]">{t.title}</h1>
    <p class="mx-auto mt-3 max-w-[720px] text-[15px] leading-[1.4] text-[#1a2352] md:text-[18px]">{t.sub}</p>
  </div>
</section>

<section class="bg-white">
  <div class="container-c grid gap-6 pb-16 pt-8 md:grid-cols-2 lg:gap-8 lg:pb-24 lg:pt-10">
    {products.map((p) => (
      <a
        href={localizePath(`/products/${p.slug}`, lang)}
        class="group flex flex-col items-start rounded-2xl border border-black/10 bg-white p-8 lg:p-10"
      >
        <Image src={p.logo} alt={p.name} densities={[1, 2]} class="h-[44px] w-auto lg:h-[54px]" />
        <p class="mt-6 flex-1 text-[15px] leading-[1.5] text-ink-soft lg:text-[16px]">{p.blurb[lang]}</p>
        <span class="btn-pill btn-pill-dark mt-8">{t.cta}</span>
      </a>
    ))}
  </div>
</section>
