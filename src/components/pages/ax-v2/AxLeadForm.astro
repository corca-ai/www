---
import type { Lang } from '../../../i18n/ui';
import { axV2ContentByLang } from './content';

interface Props {
  id: string;
  lang: Lang;
  compact?: boolean;
}

const { id, lang, compact = false } = Astro.props;
const c = axV2ContentByLang[lang].contact;
const websiteLabel = { ko: '웹사이트', en: 'Website', ja: 'ウェブサイト', zh: '网站' }[lang];
const formId = `ax-lead-${id}`;
---

<form
  class:list={['ax-v2-lead-form', { 'is-compact': compact }]}
  id={formId}
  name="ax_consultation"
  action="/api/ax/consultations"
  method="post"
  data-ax-v2-lead-form
  data-locale={lang}
  data-sending-label={c.sending}
  novalidate
>
  <div
    class="ax-v2-form-alert"
    role="alert"
    aria-live="assertive"
    aria-atomic="true"
    tabindex="-1"
    data-form-alert
    hidden
  ></div>

  <div class="ax-v2-form-grid">
    <div class="ax-v2-field">
      <label for={`${formId}-name`}>{c.labels.name}</label>
      <input
        id={`${formId}-name`}
        name="name"
        type="text"
        autocomplete="name"
        maxlength="80"
        placeholder={c.placeholders.name}
        aria-describedby={`${formId}-name-error`}
        required
      />
      <span class="ax-v2-field-error" id={`${formId}-name-error`} data-field-error="name"></span>
    </div>

    <div class="ax-v2-field">
      <label for={`${formId}-email`}>{c.labels.email}</label>
      <input
        id={`${formId}-email`}
        name="email"
        type="email"
        autocomplete="email"
        maxlength="254"
        placeholder={c.placeholders.email}
        aria-describedby={`${formId}-email-error`}
        required
      />
      <span class="ax-v2-field-error" id={`${formId}-email-error`} data-field-error="email"></span>
    </div>

    <div class="ax-v2-field ax-v2-field-interests">
      <span class="ax-v2-field-label">{c.labels.interests}</span>
      <div
        class="ax-v2-interest-options"
        role="group"
        aria-describedby={`${formId}-interests-error`}
      >
        {c.interestOptions.map((option) => (
          <label class="ax-v2-interest-option">
            <input
              type="checkbox"
              name="consulting_interests"
              value={option.value}
              data-interest-option={option.value}
            />
            <span>{option.label}</span>
          </label>
        ))}
      </div>
      <div class="ax-v2-other-interest" data-other-interest hidden>
        <label for={`${formId}-other-interest`}>{c.labels.otherInterest}</label>
        <input
          id={`${formId}-other-interest`}
          name="other_interest"
          type="text"
          maxlength="240"
          placeholder={c.placeholders.otherInterest}
          aria-describedby={`${formId}-other-interest-error`}
          disabled
          data-other-interest-input
        />
        <span
          class="ax-v2-field-error"
          id={`${formId}-other-interest-error`}
          data-field-error="other_interest"
        ></span>
      </div>
      <span
        class="ax-v2-field-error"
        id={`${formId}-interests-error`}
        data-field-error="consulting_interests"
      ></span>
    </div>

    <div class="ax-v2-field ax-v2-field-reason">
      <label for={`${formId}-reason`}>{c.labels.reason}</label>
      <textarea
        id={`${formId}-reason`}
        name="reason"
        rows="5"
        maxlength="2000"
        data-autogrow
        placeholder={c.placeholders.reason}
        aria-describedby={`${formId}-reason-error`}
        required
      ></textarea>
      <span class="ax-v2-field-error" id={`${formId}-reason-error`} data-field-error="reason"></span>
    </div>
  </div>

  <label class="ax-v2-honeypot" aria-hidden="true">
    <span>{websiteLabel}</span>
    <input name="website" tabindex="-1" autocomplete="off" />
  </label>

  {lang === 'zh' && (
    <>
      <label class="ax-v2-consent" for={`${formId}-cross-border`}>
        <input
          id={`${formId}-cross-border`}
          name="cross_border_consent"
          type="checkbox"
          value="true"
          aria-describedby={`${formId}-cross-border-error`}
          required
        />
        <span>我单独同意将咨询所需的个人信息跨境传输至韩国，并由隐私政策中列明的境外服务商处理。</span>
      </label>
      <span class="ax-v2-field-error" id={`${formId}-cross-border-error`} data-field-error="cross_border_consent"></span>
    </>
  )}

  <button class="ax-v2-primary-button ax-v2-form-submit" type="submit" disabled>
    <span data-submit-label>{c.submit}</span>
  </button>
  <p class="ax-v2-privacy-notice">{c.privacyNotice}</p>
  <p
    class="ax-v2-form-status"
    role="status"
    aria-live="polite"
    aria-atomic="true"
    tabindex="-1"
    data-form-status
  ></p>
</form>
