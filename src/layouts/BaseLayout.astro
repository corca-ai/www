---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { localeTag, ogLocale, locales, defaultLang, contact, type Lang } from '../i18n/ui';
import { absoluteUrl } from '../i18n/utils';
import { SITE_ORIGIN } from '../site';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /** Locale-agnostic base path for this page, e.g. "/" or "/moonlight". */
  basePath: string;
  /** Set false for Korean-only sections such as the blog. */
  localized?: boolean;
  ogImage?: string;
  /** Alt text for the social share image; defaults to the page title. */
  ogImageAlt?: string;
  /** Set on utility pages (404) that must stay out of the index. */
  noindex?: boolean;
  /** Extra schema.org nodes merged into the JSON-LD @graph (see structuredData.ts). */
  jsonLd?: Record<string, unknown>[];
  extraFeeds?: { title: string; type: string; href: string }[];
}

const {
  lang,
  title,
  description,
  basePath,
  localized = true,
  ogImage = '/og-default.png',
  ogImageAlt,
  noindex = false,
  jsonLd = [],
  extraFeeds = [],
} = Astro.props;

const site = Astro.site ?? new URL(SITE_ORIGIN);
const origin = site.origin;
const canonical = absoluteUrl(basePath, lang, origin);
const ogImageUrl = new URL(ogImage, site).href;
const imageAlt = ogImageAlt ?? title;
// Per the SEO meta policy (issue #15): indexable pages get plain "index, follow"
// (no author on general pages); 404 stays out. Publisher is the brand name, per
// locale (Korean pages get "코르카" as the issue specifies).
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
const publisherName = { ko: '코르카', en: 'Corca', ja: 'コルカ', zh: 'Corca' }[lang];

// hreflang alternates + x-default (points to the default locale).
const alternates = localized
  ? locales.map((l) => ({
      hreflang: localeTag[l],
      href: absoluteUrl(basePath, l, origin),
    }))
  : [];
const xDefault = localized ? absoluteUrl(basePath, defaultLang, origin) : '';
const feeds = [
  { title: 'Corca Blog RSS', type: 'application/rss+xml', href: '/rss' },
  ...extraFeeds,
];

// One JSON-LD @graph per page: the site-wide Organization + WebSite (referenced
// by @id from page nodes) plus any page-specific nodes passed in via `jsonLd`.
const orgNode = {
  '@type': 'Organization',
  '@id': `${site.href}#organization`,
  name: 'Corca',
  legalName: 'Corca, Inc.',
  url: site.href,
  logo: new URL('/favicon.png', site).href,
  email: contact.email,
  telephone: '+82-2-6925-6978',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6F, 11-8, Teheran-ro 77-gil, Gangnam-gu',
    addressLocality: 'Seoul',
    addressCountry: 'KR',
  },
  sameAs: ['https://medium.com/corca', 'https://corca.team'],
};
const webSiteNode = {
  '@type': 'WebSite',
  '@id': `${site.href}#website`,
  url: site.href,
  name: 'Corca',
  inLanguage: localeTag[lang],
  publisher: { '@id': `${site.href}#organization` },
};
const graph = {
  '@context': 'https://schema.org',
  '@graph': [orgNode, webSiteNode, ...jsonLd],
};
---

<!doctype html>
<html lang={localeTag[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="application-name" content="Corca" />
    <meta name="apple-mobile-web-app-title" content="Corca" />
    <meta name="publisher" content={publisherName} />

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-SZY1B11LXS"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-SZY1B11LXS');
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />

    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    {xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}

    {feeds.map((feed) => <link rel="alternate" type={feed.type} title={feed.title} href={feed.href} />)}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Corca" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content={ogLocale[lang]} />
    {locales.filter((l) => l !== lang).map((l) => (
      <meta property="og:locale:alternate" content={ogLocale[l]} />
    ))}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <!-- Preload the primary variable font -->
    <link
      rel="preload"
      href="/fonts/PretendardVariable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(graph)} />

    <!-- Mark JS availability synchronously so [data-reveal] elements are only
         hidden when the reveal script will actually run (no-JS keeps content
         visible). -->
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only rounded-lg bg-brand px-4 py-2 text-white focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100]"
    >
      {{ ko: '본문으로 건너뛰기', en: 'Skip to content', ja: '本文へスキップ', zh: '跳转到正文' }[lang]}
    </a>
    <Header lang={lang} basePath={basePath} localized={localized} />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer lang={lang} />

    <script>
      // Scroll-triggered reveal for [data-reveal] elements (see global.css).
      // Reduced-motion users are excluded at the CSS level, so everything
      // stays visible for them regardless of this observer.
      const revealables = document.querySelectorAll('[data-reveal]');
      if (revealables.length > 0 && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -10% 0px' },
        );
        for (const el of revealables) io.observe(el);
      } else {
        for (const el of revealables) el.classList.add('is-visible');
      }
    </script>
  </body>
</html>
