---
import BaseLayout from '../layouts/BaseLayout.astro';

const lang = 'ko' as const;
---

<BaseLayout
  lang={lang}
  title="404 | Corca"
  description="페이지를 찾을 수 없습니다."
  basePath="/404"
  noindex
>
  <section class="flex min-h-[60vh] flex-col items-center justify-center gap-6 px-5 text-center">
    <h1 class="text-[80px] font-bold leading-none text-brand">404</h1>
    <p class="text-[18px] text-ink-soft"><span lang="ko">페이지를 찾을 수 없습니다.</span> / <span lang="en">Page not found.</span> / <span lang="ja">ページが見つかりません。</span> / <span lang="zh">未找到页面。</span></p>
    <a href="/" class="btn-pill btn-pill-dark">홈으로 / Home</a>
  </section>
</BaseLayout>
