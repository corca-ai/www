---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbLd, type Crumb, softwareAppLd } from '../i18n/structuredData';
import { defaultLang, locales, ui } from '../i18n/ui';
import { products } from '../products/registry';
import { SITE_ORIGIN } from '../site';
import { staticPages, type StaticId } from '../staticPages';

// One localized route for the whole site. Static pages come from `staticPages`
// and product detail pages from the product registry, so adding a product is
// "drop a folder" — no edit here. The ko default locale is un-prefixed
// ("/news/"), en/ja/zh are prefixed ("/en/news/"); BaseLayout derives canonical
// + hreflang from basePath + lang. NB: getStaticPaths runs in an isolated scope,
// so it only reads the imported registries.
export function getStaticPaths() {
  const routes = [
    ...Object.entries(staticPages).map(([id, p]) => ({ id, basePath: p.basePath })),
    ...products.map((p) => ({ id: p.slug, basePath: `/products/${p.slug}` })),
  ];
  return locales.flatMap((lang) =>
    routes.map((r) => {
      const slug = r.basePath === '/' ? '' : r.basePath.slice(1);
      const path = `${lang === defaultLang ? '' : `${lang}/`}${slug}`;
      return { params: { slug: path === '' ? undefined : path }, props: { lang, id: r.id, basePath: r.basePath } };
    }),
  );
}

const { lang, id, basePath } = Astro.props;

// A product detail page (/products/<slug>) resolves from the product registry;
// otherwise `id` is one of the static pages (guaranteed by getStaticPaths).
const product = products.find((p) => `/products/${p.slug}` === basePath) ?? null;
const meta = product ? product.meta[lang] : staticPages[id as StaticId].meta(lang);
const Component = product ? product.Page : staticPages[id as StaticId].Component;

// Per-page schema.org nodes (merged into BaseLayout's @graph): a Home →
// …category… → page breadcrumb, plus SoftwareApplication for products with app data.
const site = Astro.site ?? new URL(SITE_ORIGIN);
// Titles read "PageName | descriptor"; the breadcrumb/app name is the part
// before the first pipe (e.g. "문라이트(Moonlight)", "비전과 미션").
const pageName = (meta.title.split('|')[0] ?? meta.title).trim();
const jsonLd: Record<string, unknown>[] = [];
if (id !== 'home') {
  const nav = ui[lang].nav;
  const crumbs: Crumb[] = [];
  if (basePath.startsWith('/products/')) crumbs.push({ name: nav.products, path: '/products' });
  else if (basePath.startsWith('/about/')) crumbs.push({ name: nav.about, path: '/about' });
  crumbs.push({ name: pageName, path: basePath });
  jsonLd.push(breadcrumbLd(site, lang, crumbs));
}
if (product?.app) jsonLd.push(softwareAppLd(site, lang, basePath, pageName, meta.description, product.app));
---

<BaseLayout lang={lang} title={meta.title} description={meta.description} basePath={basePath} jsonLd={jsonLd}>
  <Component lang={lang} />
</BaseLayout>
