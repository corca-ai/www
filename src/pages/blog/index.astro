---
import {
  BLOG_JSON_FEED_PATH,
  BLOG_RSS_PATH,
  blogPostPath,
  formatBlogDate,
  getBlogPosts,
} from '../../blog/data';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_ORIGIN } from '../../site';

const posts = await getBlogPosts();
const featured = posts[0];
const topics = [...new Set(posts.flatMap((post) => post.tags))].filter(Boolean);
const site = Astro.site ?? new URL(SITE_ORIGIN);
const title = 'Corca Blog | AI 제품, AX, 팀 운영 기록';
const description =
  'Corca가 AI 제품, AX 워크플로, 개발 조직, 팀 운영에서 배운 내용을 기록하는 공식 블로그입니다.';
const ogImage = featured?.coverPath || '/blog-assets/editorial-cover.jpg';
const extraFeeds = [
  { title: 'Corca Blog RSS', type: 'application/rss+xml', href: BLOG_RSS_PATH },
  { title: 'Corca Blog JSON Feed', type: 'application/feed+json', href: BLOG_JSON_FEED_PATH },
];
const jsonLd = [
  {
    '@type': 'Blog',
    '@id': `${site.href.replace(/\/$/, '')}/blog#blog`,
    name: 'Corca Blog',
    url: new URL('/blog', site).href,
    description,
    inLanguage: 'ko-KR',
    publisher: { '@id': `${site.href}#organization` },
  },
];
---

<BaseLayout
  lang="ko"
  title={title}
  description={description}
  basePath="/blog"
  localized={false}
  ogImage={ogImage}
  ogImageAlt={featured ? `${featured.title} 대표 이미지` : 'Corca Blog'}
  extraFeeds={extraFeeds}
  jsonLd={jsonLd}
>
  <section class="bg-gradient-to-b from-[#e1eaf7] to-white">
    <div class="container-c pb-10 pt-10 text-center lg:pt-24">
      <p class="text-[15px] font-semibold tracking-[0.08em] text-brand-ink">Corca Blog</p>
      <h1 class="mx-auto mt-3 max-w-[920px] font-body text-[34px] font-normal leading-[1.18] text-[#1a2352] md:text-[48px] lg:text-[64px]">
        AI로 일하고 제품을 만드는 기록
      </h1>
      <p class="mx-auto mt-5 max-w-[760px] text-[17px] leading-[1.8] text-ink-soft md:text-[19px]">
        제품, AX 워크플로, 개발 문화, 팀 운영에서 Corca가 직접 실험하고 배운 내용을 정리합니다.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-2">
        {topics.map((topic) => (
          <span class="rounded-full border border-brand/15 bg-white px-4 py-2 text-[14px] font-medium text-brand-ink shadow-sm">
            {topic}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="container-c py-12 lg:py-20" aria-labelledby="blog-posts-title">
    <div class="mb-8 flex flex-col gap-3 md:mb-10 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-[14px] font-semibold text-brand">Latest Posts</p>
        <h2 id="blog-posts-title" class="mt-2 font-body text-[28px] font-normal text-[#1a2352] md:text-[40px]">
          전체 글
        </h2>
      </div>
      <a href={BLOG_RSS_PATH} class="text-[15px] font-medium text-brand-ink hover:text-brand">
        RSS 구독
      </a>
    </div>

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <article class="group overflow-hidden rounded-lg border border-black/[0.08] bg-white shadow-[0_18px_45px_-28px_rgba(31,45,80,0.35)] transition hover:-translate-y-0.5 hover:shadow-[0_24px_55px_-28px_rgba(31,45,80,0.45)]">
          <a href={blogPostPath(post)} class="block">
            <div class="aspect-[16/9] overflow-hidden bg-black/5">
              <img
                src={post.coverPath}
                alt=""
                loading={post === featured ? 'eager' : 'lazy'}
                decoding="async"
                class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
              />
            </div>
            <div class="flex min-h-[260px] flex-col p-5">
              <div class="flex flex-wrap gap-2">
                {post.tags.slice(0, 2).map((tag) => (
                  <span class="rounded-full bg-brand/8 px-2.5 py-1 text-[12px] font-semibold text-brand-ink">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="mt-4 text-[20px] font-semibold leading-[1.35] text-[#17213f]">
                {post.title}
              </h3>
              <p class="mt-3 line-clamp-3 text-[15px] leading-[1.7] text-ink-soft">
                {post.description}
              </p>
              <div class="mt-auto flex items-center justify-between gap-3 pt-6 text-[13px] text-ink-soft">
                <time datetime={post.date}>{formatBlogDate(post.date)}</time>
                <span>{post.readingTime}</span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
