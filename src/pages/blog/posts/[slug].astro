---
import {
  BLOG_JSON_FEED_PATH,
  BLOG_RSS_PATH,
  blogPostLanguage,
  blogPostPath,
  formatBlogDate,
  getBlogPost,
  getBlogPosts,
  relatedBlogPosts,
} from '../../../blog/data';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE_ORIGIN } from '../../../site';

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const slug = Astro.params.slug || '';
const post = await getBlogPost(slug);
if (!post) throw new Error(`Unknown blog post slug: ${slug}`);

const posts = await getBlogPosts();
const related = relatedBlogPosts(post, posts);
const site = Astro.site ?? new URL(SITE_ORIGIN);
const canonical = new URL(blogPostPath(post), site).href;
const image = new URL(post.coverPath, site).href;
const title = `${post.title} | Corca Blog`;
const extraFeeds = [
  { title: 'Corca Blog RSS', type: 'application/rss+xml', href: BLOG_RSS_PATH },
  { title: 'Corca Blog JSON Feed', type: 'application/feed+json', href: BLOG_JSON_FEED_PATH },
];
const jsonLd = [
  {
    '@type': 'BlogPosting',
    headline: post.title,
    description: post.description,
    image,
    thumbnailUrl: image,
    url: canonical,
    keywords: post.tags,
    articleSection: post.section || post.tags[0] || '코르카',
    wordCount: post.wordCount,
    datePublished: post.date,
    dateModified: post.date,
    author: {
      '@type': 'Organization',
      name: post.author,
    },
    publisher: { '@id': `${site.href}#organization` },
    inLanguage: blogPostLanguage(post) === 'en' ? 'en-US' : 'ko-KR',
    isPartOf: {
      '@type': 'Blog',
      name: 'Corca Blog',
      url: new URL('/blog', site).href,
    },
    mainEntityOfPage: canonical,
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Corca Blog',
        item: new URL('/blog', site).href,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: post.title,
        item: canonical,
      },
    ],
  },
];
---

<BaseLayout
  lang="ko"
  title={title}
  description={post.description}
  basePath={blogPostPath(post)}
  localized={false}
  ogImage={post.coverPath}
  ogImageAlt={post.coverAlt || `${post.title} 대표 이미지`}
  extraFeeds={extraFeeds}
  jsonLd={jsonLd}
>
  <article class="bg-white">
    <header class="container-c pb-8 pt-10 lg:pb-12 lg:pt-20">
      <a href="/blog" class="text-[15px] font-semibold text-brand hover:text-brand-ink">Corca Blog</a>
      <div class="mt-5 flex flex-wrap gap-2">
        {post.tags.map((tag) => (
          <span class="rounded-full bg-brand/8 px-3 py-1.5 text-[13px] font-semibold text-brand-ink">
            {tag}
          </span>
        ))}
      </div>
      <h1 class="mt-5 max-w-[980px] font-body text-[34px] font-normal leading-[1.18] text-[#1a2352] md:text-[48px] lg:text-[62px]">
        {post.title}
      </h1>
      <p class="mt-5 max-w-[820px] text-[18px] leading-[1.75] text-ink-soft">
        {post.description}
      </p>
      <div class="mt-7 flex flex-wrap items-center gap-x-4 gap-y-2 text-[14px] text-ink-soft">
        <span>{post.author}</span>
        <time datetime={post.date}>{formatBlogDate(post.date)}</time>
        <span>{post.readingTime}</span>
      </div>
    </header>

    <div class="container-c">
      <img
        src={post.coverPath}
        alt=""
        loading="eager"
        decoding="async"
        class="aspect-[16/9] w-full rounded-lg object-cover"
      />
    </div>

    <div class="container-c grid gap-10 py-10 lg:grid-cols-[minmax(0,760px)_260px] lg:items-start lg:py-16">
      <div>
        <div
          class="blog-article max-w-none text-[17px] leading-[1.85] text-[#20263a]"
          data-blog-post={post.slug}
          set:html={post.articleHtml}
        />

        <div
          class="mt-12 flex flex-wrap items-center gap-2 border-t border-black/10 pt-6"
          data-blog-actions
          data-slug={post.slug}
        >
          <button type="button" class="rounded-full border border-black/15 px-4 py-2 text-[14px] font-medium text-[#1a2352] hover:border-brand hover:text-brand" data-blog-share>
            공유
          </button>
          <button type="button" class="rounded-full border border-black/15 px-4 py-2 text-[14px] font-medium text-[#1a2352] hover:border-brand hover:text-brand" data-blog-download>
            HTML 저장
          </button>
          <p class="sr-only" aria-live="polite" data-blog-action-status></p>
        </div>
      </div>

      <aside class="lg:sticky lg:top-24">
        {post.toc.filter((item) => item.level === 2).length > 1 && (
          <nav class="rounded-lg border border-black/[0.08] bg-white p-5 shadow-[0_18px_45px_-34px_rgba(31,45,80,0.4)]" aria-label="글 목차">
            <strong class="text-[14px] text-[#1a2352]">목차</strong>
            <ol class="mt-3 space-y-2">
              {post.toc.filter((item) => item.level === 2).map((item) => (
                <li>
                  <a href={`#${item.id}`} class="block text-[14px] leading-[1.5] text-ink-soft hover:text-brand">
                    {item.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        )}
      </aside>
    </div>
  </article>

  {related.length > 0 && (
    <section class="bg-[#f5f8fc] py-12 lg:py-16" aria-labelledby="related-blog-posts">
      <div class="container-c">
        <h2 id="related-blog-posts" class="font-body text-[28px] font-normal text-[#1a2352] md:text-[36px]">
          이어서 읽기
        </h2>
        <div class="mt-7 grid gap-4 md:grid-cols-3">
          {related.map((item) => (
            <a href={blogPostPath(item)} class="block rounded-lg border border-black/[0.08] bg-white p-5 shadow-[0_18px_45px_-34px_rgba(31,45,80,0.35)] hover:border-brand/40">
              <span class="text-[13px] font-medium text-brand">{formatBlogDate(item.date)}</span>
              <strong class="mt-3 block text-[18px] leading-[1.4] text-[#1a2352]">{item.title}</strong>
              <span class="mt-4 block text-[14px] text-ink-soft">{item.readingTime}</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <script is:inline src="/blog-client.js" type="module"></script>
</BaseLayout>

<style is:global>
  .blog-article > * + * {
    margin-top: 1.15em;
  }

  .blog-article h2,
  .blog-article h3 {
    color: #1a2352;
    font-weight: 650;
    line-height: 1.3;
    scroll-margin-top: 96px;
  }

  .blog-article h2 {
    margin-top: 2.2em;
    font-size: clamp(1.65rem, 2vw, 2.2rem);
  }

  .blog-article h3 {
    margin-top: 1.75em;
    font-size: clamp(1.25rem, 1.45vw, 1.55rem);
  }

  .blog-article p,
  .blog-article li {
    color: #30384f;
  }

  .blog-article a {
    color: #006fbe;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .blog-article ul,
  .blog-article ol {
    padding-left: 1.4em;
  }

  .blog-article ul {
    list-style: disc;
  }

  .blog-article ol {
    list-style: decimal;
  }

  .blog-article blockquote {
    border-left: 3px solid #0084d6;
    padding-left: 1rem;
    color: #4c5873;
  }

  .blog-article figure {
    margin: 2rem 0;
  }

  .blog-article img,
  .blog-article video {
    height: auto;
    max-width: 100%;
    border-radius: 8px;
  }

  .blog-article table {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
  }

  .blog-article th,
  .blog-article td {
    border: 1px solid rgba(0, 0, 0, 0.12);
    padding: 0.65rem 0.8rem;
    text-align: left;
  }
</style>
