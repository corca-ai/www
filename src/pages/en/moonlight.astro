---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Moonlight from '../../components/pages/Moonlight.astro';
import { pageMeta } from '../../i18n/pageMeta';

const lang = 'en' as const;
const m = pageMeta.moonlight[lang];
---

<BaseLayout lang={lang} title={m.title} description={m.description} basePath="/moonlight">
  <Moonlight lang={lang} />
</BaseLayout>
