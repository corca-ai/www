---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Colleagues from '../../components/pages/Colleagues.astro';
import { pageMeta } from '../../i18n/pageMeta';

const lang = 'ja' as const;
const m = pageMeta.colleagues[lang];
---

<BaseLayout lang={lang} title={m.title} description={m.description} basePath="/colleagues">
  <Colleagues lang={lang} />
</BaseLayout>
