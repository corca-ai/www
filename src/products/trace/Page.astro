---
import type { Lang } from '../../i18n/ui';
import { br } from '../../text';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

const P = '/images/pages/';
const HERO_POSTER = `${P}2fe9a6_4b78885029854f5daeb2e6b97cc72baaf000.webp`;
// Original Wix hero background: concentric circles with a rotating clock.
const HERO_VIDEO = '/videos/trace-hero.mp4';
const BADGE = `${P}2fe9a6_32ebaebce4ec4c2e83c49bb9eb147c21.webp`;
const LOGO = `${P}2fe9a6_ed110dd31d37412ab81cbcbe0b9a30cc.webp`;
const APPSTORE = `${P}2fe9a6_6bc0705e6e9245658b307e1b1a6b0bcc.webp`;
const PHONE_CHAT = `${P}2fe9a6_c29d890e90d04eff8faaf751a934e297.webp`; // top-right chat
const PHONE_CAL = `${P}2fe9a6_762fd195e5f1497faade479d0af4b12b.webp`; // center calendar widget
const PHONE_HOME = `${P}2fe9a6_1210239befb1472284d6ac3ddc9c335f.webp`; // big right + notifications
const PHONE_EVENTS = `${P}2fe9a6_054c526e4498482bade3326d493410f1.webp`; // left event cards
const APP_URL = 'https://apps.apple.com/app/id6503812022';


const content = {
  ko: {
    title: '말 한마디로 완벽한 일정관리',
    body: '트레이스는 당신의 하루를 손쉽게 관리해주는 AI 캘린더입니다. 말하거나, 입력하거나, 사진을 찍기만 하면 AI가 내용을 이해해 일정을 자동으로 정리하고 당신의 생활 리듬에 맞춰 알림과 루틴을 똑똑하게 챙겨드립니다.',
    cta: '스마트한 일정 관리가 필요하신가요? 지금 Trace를 다운로드하고 일정 관리의 편리함을 경험해 보세요.',
    appStoreAlt: 'App Store에서 다운로드',
    badgeAlt: "Product Hunt '오늘의 제품' 4위 선정",
    appShotAlt: '트레이스 앱 화면',
  },
  en: {
    title: 'Just tell me your schedule',
    body: 'Trace is an AI calendar that makes managing your day easy. Simply speak, type, or take a photo, and the AI will understand your content, automatically organize your schedule, and intelligently manage reminders and routines to suit your daily rhythm.',
    cta: 'Need smarter scheduling? Download Trace now and experience effortless schedule management.',
    appStoreAlt: 'Download on the App Store',
    badgeAlt: 'Product Hunt — #4 Product of the Day',
    appShotAlt: 'Trace app screen',
  },
  ja: {
    title: '話すだけで予定が登録される\nAIスケジューリングアプリ',
    body: 'トレースは、あなたの一日をスマートに管理するAIスケジューリングアプリです。話す・入力する・写真を撮るだけで、AIが内容を理解し、自動でスケジュールを整理します。あなたのライフリズムに合わせて、通知やルーチンを最適なタイミングでお届けします。',
    cta: 'スマートなスケジュール管理をお探しですか？今すぐTraceをダウンロードして、その便利さを体験してください。',
    appStoreAlt: 'App Storeでダウンロード',
    badgeAlt: 'Product Hunt「本日のプロダクト」第4位',
    appShotAlt: 'トレースのアプリ画面',
  },
  zh: {
    title: '一句话，轻松搞定日程管理',
    body: 'Trace是一款帮助您轻松管理一天的AI日历。只需说话、输入或拍照，AI就能理解内容并自动整理日程，还会根据您的生活节奏智能地安排提醒与例行事项。',
    cta: '需要更智能的日程管理吗？立即下载Trace，体验日程管理的便捷。',
    appStoreAlt: '在App Store下载',
    badgeAlt: 'Product Hunt“今日产品”第4名',
    appShotAlt: 'Trace 应用界面',
  },
};
const c = content[lang];
---

<section class="relative overflow-hidden bg-[#745add] text-white">
  <!-- Rotating-clock background video at 20% opacity over the flat #745add base
       — exactly how live corca.ai composites it (video opacity .2, no tint
       overlay), so the clock stays visibly detailed and the hero rests at
       ~#5e51c0. Decorative (aria-hidden); the poster is the reduced-motion /
       no-JS fallback. -->
  <video
    id="trace-hero-video"
    class="pointer-events-none absolute inset-0 h-full w-full object-cover object-top opacity-20"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={HERO_POSTER}
    aria-hidden="true"
    tabindex="-1"
  >
    <source src={HERO_VIDEO} type="video/mp4" />
  </video>

  <!-- top-right chat phone (tablet+ , peeking) — bleeds above the top edge and
       sits at the right like live corca.ai (live: ~y-120/w320 at desktop). -->
  <img src={PHONE_CHAT} alt="" loading="lazy" decoding="async" class="pointer-events-none absolute right-[2%] top-[-112px] hidden w-[300px] select-none md:block lg:right-[16%] lg:top-[-185px] lg:w-[320px]" />

  <!-- Content -->
  <div class="container-c relative z-10 flex flex-col items-center gap-6 pt-6 pb-10 text-center sm:pt-12 lg:gap-9 lg:pt-20">
    <img src={BADGE} alt={c.badgeAlt} width="223" height="48" class="h-[45px] w-auto sm:h-[36px] lg:h-[41px] xl:h-[48px]" data-reveal />
    <img src={LOGO} alt="Trace" width="352" height="106" class="mt-2 w-[181px] max-w-full sm:w-[210px] lg:w-[302px] xl:w-[352px]" data-reveal style="--reveal-delay: .08s" />
    <h1 class="mt-2 text-[27px] font-normal leading-[1.2] sm:text-[36px] lg:text-[52px] xl:text-[60px]" set:html={br(c.title)} data-reveal style="--reveal-delay: .16s" />
    <p class="max-w-[760px] text-[15px] leading-[1.4] text-white md:text-[17px] lg:max-w-[840px] lg:text-[18px]" set:html={br(c.body)} data-reveal style="--reveal-delay: .24s" />
    <p class="font-head max-w-[720px] text-[15px] leading-[1.4] text-white md:text-[18px]" set:html={br(c.cta)} data-reveal style="--reveal-delay: .3s" />
    <a href={APP_URL} target="_blank" rel="noopener" class="mt-3 inline-block" data-reveal style="--reveal-delay: .36s">
      <img src={APPSTORE} alt={c.appStoreAlt} width="324" height="95" class="h-[76px] w-auto sm:h-[58px] lg:h-[92px]" />
    </a>
  </div>

  <!-- Phone collage — shown from tablet up (md), like live corca.ai which keeps
       the four-phone montage down to ~768px. Fixed pixel sizes per tier (md/lg)
       instead of container-% so the phones don't shrink between 1024–1280 the
       way live's fixed-size montage doesn't. -->
  <div class="relative mx-auto hidden h-[784px] w-full max-w-[1180px] md:block lg:h-[825px] lg:max-w-[1200px]">
    <img src={PHONE_EVENTS} alt="" loading="lazy" decoding="async" class="absolute bottom-[88px] left-[1%] w-[400px] lg:bottom-[132px] lg:w-[500px]" data-reveal style="--reveal-delay: .1s" />
    <img src={PHONE_CAL} alt="" loading="lazy" decoding="async" class="absolute bottom-[345px] left-[33%] z-20 w-[287px] lg:bottom-[393px] lg:left-[37%] lg:w-[359px]" data-reveal style="--reveal-delay: .25s" />
    <img src={PHONE_HOME} alt="" loading="lazy" decoding="async" class="absolute bottom-0 right-[7%] w-[493px] lg:right-[4%] lg:w-[657px]" data-reveal style="--reveal-delay: .4s" />
  </div>

  <!-- Mobile (<768): four-phone montage echoing live's mobile layout (phones
       bleed past both edges; the section's overflow-hidden clips them). -->
  <div class="relative mx-auto block h-[680px] w-full max-w-[420px] md:hidden">
    <img src={PHONE_CHAT} alt="" loading="lazy" decoding="async" class="absolute left-[41%] top-[0px] z-10 w-[240px] max-w-none" data-reveal style="--reveal-delay: .1s" />
    <img src={PHONE_CAL} alt="" loading="lazy" decoding="async" class="absolute left-0 top-[32px] z-20 w-[180px] max-w-none" data-reveal style="--reveal-delay: .2s" />
    <img src={PHONE_EVENTS} alt="" loading="lazy" decoding="async" class="absolute left-[-27%] top-[165px] w-[240px] max-w-none" data-reveal style="--reveal-delay: .3s" />
    <img src={PHONE_HOME} alt={c.appShotAlt} loading="lazy" decoding="async" class="absolute left-[4%] top-[135px] w-[450px] max-w-none" data-reveal style="--reveal-delay: .4s" />
  </div>
</section>

<script>
  // Respect prefers-reduced-motion for the decorative background video: stop
  // playback and fall back to the static poster frame.
  const video = document.getElementById('trace-hero-video') as HTMLVideoElement | null;
  if (video && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    video.removeAttribute('autoplay');
    video.pause();
  }
</script>
