---
import type { Lang } from '../../i18n/ui';
import background from './assets/figma-background.png';
import logoDesktop from './assets/figma-logo-desktop.png';
import logoMobile from './assets/figma-logo-mobile.png';
import awardMobile from './assets/figma-award-mobile.png';
import productDesktop from './assets/figma-product-desktop.png';
import productMobile from './assets/figma-product-mobile.png';
import appStoreApple from './assets/figma-appstore-apple.svg';
import appStoreTitle from './assets/figma-appstore-title.svg';
import appStoreKicker from './assets/figma-appstore-kicker.svg';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const APP_URL = 'https://apps.apple.com/app/id6503812022';

const content = {
  ko: {
    title: '말 한마디로 완벽한 일정관리',
    body: '트레이스는 당신의 하루를 손쉽게 관리해주는 AI 캘린더입니다. 말하거나, 입력하거나, 사진을 찍기만 하면 AI가 내용을 이해해 일정을 자동으로 정리하고 당신의 생활 리듬에 맞춰 알림과 루틴을 똑똑하게 챙겨드립니다.',
    cta: '스마트한 일정 관리가 필요하신가요? 지금 Trace를 다운로드하고 일정 관리의 편리함을 경험해 보세요.',
    appStoreAlt: 'App Store에서 다운로드',
    appShotAlt: '트레이스 앱 화면과 일정 알림 기능',
  },
  en: {
    title: 'Just tell me your schedule',
    body: 'Trace is an AI calendar that makes managing your day easy. Simply speak, type, or take a photo, and the AI will understand your content, automatically organize your schedule, and intelligently manage reminders and routines to suit your daily rhythm.',
    cta: 'Need smarter scheduling? Download Trace now and experience effortless schedule management.',
    appStoreAlt: 'Download on the App Store',
    appShotAlt: 'Trace app screens and scheduling notifications',
  },
  ja: {
    title: '話すだけで予定が登録される AIスケジューリングアプリ',
    body: 'トレースは、あなたの一日をスマートに管理するAIスケジューリングアプリです。話す・入力する・写真を撮るだけで、AIが内容を理解し、自動でスケジュールを整理します。あなたのライフリズムに合わせて、通知やルーチンを最適なタイミングでお届けします。',
    cta: 'スマートなスケジュール管理をお探しですか？今すぐTraceをダウンロードして、その便利さを体験してください。',
    appStoreAlt: 'App Storeでダウンロード',
    appShotAlt: 'トレースのアプリ画面とスケジュール通知機能',
  },
  zh: {
    title: '一句话，轻松搞定日程管理',
    body: 'Trace是一款帮助您轻松管理一天的AI日历。只需说话、输入或拍照，AI就能理解内容并自动整理日程，还会根据您的生活节奏智能地安排提醒与例行事项。',
    cta: '需要更智能的日程管理吗？立即下载Trace，体验日程管理的便捷。',
    appStoreAlt: '在App Store下载',
    appShotAlt: 'Trace 应用界面和日程提醒功能',
  },
};

const c = content[lang];
const japaneseTitleLines = ['話すだけで予定が登録される', 'AIスケジューリングアプリ'];
---

<section class="relative isolate overflow-hidden bg-white text-[#403258]">
  <img
    src={background.src}
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute inset-[-4%] -z-10 h-[108%] w-[108%] max-w-none object-cover blur-[25px]"
  />

  <!-- Mobile and tablet: the visual leads, followed by fluid-height copy. -->
  <div class="mx-auto flex w-full max-w-[680px] flex-col items-center px-10 pb-[57px] pt-[73px] lg:hidden">
    <div class="flex flex-col items-center gap-6">
      <img src={logoMobile.src} alt="Trace" width="430" height="417" class="h-[115px] w-[119px] object-cover" />
      <div class="flex flex-col items-center gap-5 pl-2">
        <img src={awardMobile.src} alt="Product Hunt — #4 Product of the Day" width="666" height="200" class="h-auto w-[136px]" />
        <img src={productMobile.src} alt={c.appShotAlt} width="1332" height="1324" class="h-auto w-full max-w-[420px] sm:w-[min(55vw,420px)]" />
      </div>
    </div>

    <div class="mt-[38px] flex w-full max-w-[560px] flex-col items-start gap-7">
      <h1 class="font-body text-[32px] font-bold leading-[1.3] tracking-[-0.03em] text-[#1f0d3f] [overflow-wrap:anywhere] sm:text-[40px]">
        {c.title}
      </h1>
      <div
        class:list={[
          'flex min-w-0 w-full max-w-full flex-col gap-[30px] text-[16px] font-medium leading-[1.55] tracking-[-0.03em] sm:text-[18px]',
          lang === 'ja' && '[word-break:normal] [overflow-wrap:anywhere]',
        ]}
      >
        <p style={lang === 'ja' ? 'word-break: normal' : undefined}>{c.body}</p>
        <p style={lang === 'ja' ? 'word-break: normal' : undefined}>{c.cta}</p>
      </div>
      <a
        href={APP_URL}
        target="_blank"
        rel="noopener"
        aria-label={c.appStoreAlt}
        class="relative mt-[10px] block h-[52px] w-[165px] rounded-[16px] bg-[#080808] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#1f0d3f]"
      >
        <img src={appStoreApple.src} alt="" class="absolute left-[13.74%] top-[21.89%] h-[51.18%] w-[13.55%]" />
        <img src={appStoreKicker.src} alt="" class="absolute left-[33.9%] top-[22.56%] h-[14.01%] w-[50.62%]" />
        <img src={appStoreTitle.src} alt="" class="absolute left-[33.08%] top-[45.53%] h-[34.94%] w-[52.06%]" />
      </a>
    </div>
  </div>

  <!-- Desktop: preserve the Figma two-column composition while copy grows vertically by locale. -->
  <div class="mx-auto hidden min-h-[900px] w-[84.1%] max-w-[1211px] grid-cols-[44%_45.3%] items-center gap-[10.7%] lg:grid xl:min-h-[950px] xl:translate-x-[30px]">
    <div class="flex min-w-0 flex-col items-start gap-10">
      <img src={logoDesktop.src} alt="Trace" width="1164" height="540" class="h-auto w-[190px] xl:w-[235px]" />
      <div class="flex w-full flex-col items-start gap-[clamp(36px,3.7vw,53px)]">
        <h1
          class:list={[
            'font-body font-bold leading-[1.3] tracking-[-0.03em] text-[#1f0d3f]',
            lang === 'ja' ? 'text-[27px] xl:text-[38px]' : 'text-[40px] [overflow-wrap:anywhere] xl:text-[50px]',
          ]}
        >
          {
            lang === 'ja'
              ? japaneseTitleLines.map((line) => <span class="block whitespace-nowrap">{line}</span>)
              : c.title
          }
        </h1>
        <div class="flex w-full max-w-[485px] flex-col gap-[30px] text-[18px] font-medium leading-[1.5] tracking-[-0.03em] xl:text-[20px]">
          <p>{c.body}</p>
          <p class="leading-[1.3]">{c.cta}</p>
        </div>
      </div>
      <a
        href={APP_URL}
        target="_blank"
        rel="noopener"
        aria-label={c.appStoreAlt}
        class="relative block h-[64px] w-[202px] rounded-[16px] bg-[#080808] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#1f0d3f] xl:h-[79px] xl:w-[249px]"
      >
        <img src={appStoreApple.src} alt="" class="absolute left-[13.74%] top-[21.89%] h-[51.18%] w-[13.55%]" />
        <img src={appStoreKicker.src} alt="" class="absolute left-[33.9%] top-[22.56%] h-[14.01%] w-[50.62%]" />
        <img src={appStoreTitle.src} alt="" class="absolute left-[33.08%] top-[45.53%] h-[34.94%] w-[52.06%]" />
      </a>
    </div>

    <img
      src={productDesktop.src}
      alt={c.appShotAlt}
      width="1208"
      height="1220"
      class="h-auto w-full xl:translate-y-[20px]"
    />
  </div>
</section>
